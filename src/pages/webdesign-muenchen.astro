---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Webdesign München — professionelle Websites für den Mittelstand | botmanufactory"
  description="Webdesign München: Professionelle Websites für Handwerker, Arztpraxen und KMU. Persönlich vor Ort in München und Umgebung. Fertig in 3-6 Wochen. Jetzt anfragen."
  canonical="https://botmanufactory.de/webdesign-muenchen"
>
  <Nav />
  <main>

    <!-- Hero -->
    <section class="leistung-hero section-padding">
      <div class="hero-bg" aria-hidden="true">
        <div class="hero-glow-1"></div>
        <div class="hero-glow-2"></div>
      </div>
      <div class="container">
        <div class="hero-badge reveal">
          <span class="badge-dot" aria-hidden="true"></span>
          Webdesign München
        </div>
        <h1 class="reveal" data-delay="0.1">
          Webdesign München —<br />
          <span class="text-amber">Websites die wirklich Kunden bringen.</span>
        </h1>
        <p class="hero-sub reveal" data-delay="0.2">
          Professionelles Webdesign für Handwerker, Arztpraxen und Unternehmen in München und Umgebung. Kein Ferndienstleister, kein Template: Wir kommen persönlich vorbei, verstehen Ihr Unternehmen und bauen eine Website, die tatsächlich Anfragen generiert.
        </p>
        <div class="hero-ctas reveal" data-delay="0.3">
          <a href="#kontakt" class="btn-primary">Kostenloses Erstgespräch</a>
          <a href="#leistungen" class="btn-secondary">Was wir anbieten</a>
        </div>
        <div class="hero-trust reveal" data-delay="0.4">
          <span class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" stroke="var(--color-primary)" stroke-width="1.5"/><circle cx="12" cy="10" r="3" stroke="var(--color-primary)" stroke-width="1.5"/></svg>
            München & Umgebung · Persönlich vor Ort
          </span>
          <span class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/><polyline points="22 4 12 14.01 9 11.01" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Fertig in 3–6 Wochen
          </span>
          <span class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/><polyline points="22 4 12 14.01 9 11.01" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            KI-ready von Anfang an
          </span>
        </div>
      </div>
    </section>

    <!-- Lokaler USP -->
    <section class="section-padding regional-section">
      <div class="container">
        <div class="regional-grid">
          <div class="regional-text reveal">
            <div class="section-label">Warum lokal?</div>
            <h2>Wir kennen den Münchner Markt — von innen.</h2>
            <p>Was ein Elektriker in Trudering braucht, ist etwas anderes als was eine Privatpraxis in Schwabing braucht. Wir arbeiten seit Jahren mit Unternehmen in München und Umgebung — und kennen die Erwartungen, den Wettbewerb und die Sprache des Markts.</p>
            <p>Dazu: Wir kommen zu Ihnen. Kein Videocall-Ping-Pong, keine Missverständnisse durch fehlende E-Mails. Wenn etwas besprochen werden muss, sitzen wir am selben Tisch.</p>
          </div>
          <div class="regional-locations reveal" data-delay="0.1">
            <div class="section-label">Persönlich vor Ort in</div>
            <div class="locations-grid">
              <div class="location-item">
                <div class="loc-dot" aria-hidden="true"></div>
                <div>
                  <div class="loc-name">München</div>
                  <div class="loc-desc">Hauptmarkt · alle Stadtteile</div>
                </div>
              </div>
              <div class="location-item">
                <div class="loc-dot" aria-hidden="true"></div>
                <div>
                  <div class="loc-name">Vaterstetten</div>
                  <div class="loc-desc">Heimatstandort</div>
                </div>
              </div>
              <div class="location-item">
                <div class="loc-dot loc-secondary" aria-hidden="true"></div>
                <div>
                  <div class="loc-name">Landkreis Ebersberg</div>
                  <div class="loc-desc">Baldham, Poing, Kirchseeon</div>
                </div>
              </div>
              <div class="location-item">
                <div class="loc-dot loc-secondary" aria-hidden="true"></div>
                <div>
                  <div class="loc-name">Landshut · Augsburg</div>
                  <div class="loc-desc">Regionale Präsenz</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Leistungen -->
    <section class="section-padding" id="leistungen">
      <div class="container">
        <div class="section-label reveal">Was wir bauen</div>
        <h2 class="reveal" data-delay="0.1">Webdesign in München — das wirklich liefert.</h2>
        <div class="features-grid">
          <div class="feature-card card reveal" data-delay="0.1">
            <div class="feature-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><rect x="5" y="2" width="14" height="20" rx="2" stroke="var(--color-primary)" stroke-width="1.5"/><line x1="12" y1="18" x2="12.01" y2="18" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round"/></svg>
            </div>
            <h3>Responsive Design</h3>
            <p>Perfekt auf Smartphone, Tablet und Desktop — von Anfang an. Nicht als Nachgedanke, sondern als Ausgangspunkt.</p>
          </div>
          <div class="feature-card card reveal" data-delay="0.15">
            <div class="feature-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="8" stroke="var(--color-primary)" stroke-width="1.5"/><path d="m21 21-4.35-4.35" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3>SEO-optimiert von Beginn an</h3>
            <p>Technisches SEO, schnelle Ladezeiten, strukturierte Daten — damit Google Ihre Website von Anfang an richtig einordnet.</p>
          </div>
          <div class="feature-card card reveal" data-delay="0.2">
            <div class="feature-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3>DSGVO-konform</h3>
            <p>Cookie-Banner, Datenschutzerklärung, Impressum — alles rechtssicher. Kein Abmahnrisiko, kein Nacharbeit.</p>
          </div>
          <div class="feature-card card reveal" data-delay="0.25">
            <div class="feature-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="18" rx="2" stroke="var(--color-primary)" stroke-width="1.5"/><path d="M16 2v4M8 2v4M3 10h18" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <h3>Terminbuchung integriert</h3>
            <p>Google Calendar, Calendly oder Ihr bestehendes System — direkte Buchung auf der Website, ohne Hin- und Her-Telefonieren.</p>
          </div>
          <div class="feature-card card reveal" data-delay="0.3">
            <div class="feature-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3>KI-ready von Anfang an</h3>
            <p>Jede Website die wir bauen, ist so konzipiert, dass KI-Funktionen nahtlos ergänzt werden können — Chatbot, Voice Agent, Automatisierungen.</p>
          </div>
          <div class="feature-card card reveal" data-delay="0.35">
            <div class="feature-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><polyline points="14 2 14 8 20 8" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><line x1="16" y1="13" x2="8" y2="13" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/><line x1="16" y1="17" x2="8" y2="17" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <h3>CMS zum Selbstpflegen</h3>
            <p>Texte, Bilder, Preise selbst ändern — ohne Programmierkenntnisse. Damit Sie nicht für jede Kleinigkeit anfragen müssen.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Vorteile gegenüber großen Agenturen -->
    <section class="section-padding vergleich-section">
      <div class="container">
        <div class="section-label reveal">Der Unterschied</div>
        <h2 class="reveal" data-delay="0.1">Botmanufactory vs. große Webdesign-Agenturen.</h2>
        <div class="vergleich-table reveal" data-delay="0.1">
          <div class="vt-header">
            <div class="vt-col-label">Aspekt</div>
            <div class="vt-col">Große Agentur</div>
            <div class="vt-col vt-col-us">Botmanufactory</div>
          </div>
          <div class="vt-row">
            <div class="vt-col-label">Ansprechpartner</div>
            <div class="vt-col">Wechselnde Projektmanager</div>
            <div class="vt-col vt-col-us text-amber">Michael Segl — direkt</div>
          </div>
          <div class="vt-row">
            <div class="vt-col-label">Vor-Ort-Besuche</div>
            <div class="vt-col">Selten oder nie</div>
            <div class="vt-col vt-col-us text-amber">Immer möglich in München und Bayern</div>
          </div>
          <div class="vt-row">
            <div class="vt-col-label">Umsetzungszeit</div>
            <div class="vt-col">3–6 Monate</div>
            <div class="vt-col vt-col-us text-amber">3–6 Wochen</div>
          </div>
          <div class="vt-row">
            <div class="vt-col-label">KI-Integration</div>
            <div class="vt-col">Extra-Auftrag, extra Kosten</div>
            <div class="vt-col vt-col-us text-amber">Direkt integriert, aus einer Hand</div>
          </div>
          <div class="vt-row">
            <div class="vt-col-label">Preise</div>
            <div class="vt-col">Für Konzernbudgets ausgelegt</div>
            <div class="vt-col vt-col-us text-amber">Faire KMU-Preise durch KI im Prozess</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Prozess -->
    <section class="section-padding prozess-section">
      <div class="container">
        <div class="section-label reveal">Unser Vorgehen</div>
        <h2 class="reveal" data-delay="0.1">Von der Idee zur fertigen Website — in 4 Schritten.</h2>
        <div class="prozess-steps">
          <div class="prozess-step reveal" data-delay="0.1">
            <div class="step-number mono text-amber">01</div>
            <div class="step-content">
              <h3>Kennenlernen vor Ort</h3>
              <p>Wir kommen zu Ihnen — nach München, ins Umland oder per Video. Wir lernen Ihr Unternehmen, Ihre Kunden und Ihre Ziele kennen.</p>
            </div>
          </div>
          <div class="prozess-step reveal" data-delay="0.2">
            <div class="step-number mono text-amber">02</div>
            <div class="step-content">
              <h3>Konzept und Design</h3>
              <p>Sie sehen das Konzept und das Design, bevor wir bauen. Keine Überraschungen, keine versteckten Änderungswünsche am Ende.</p>
            </div>
          </div>
          <div class="prozess-step reveal" data-delay="0.3">
            <div class="step-number mono text-amber">03</div>
            <div class="step-content">
              <h3>Umsetzung und Test</h3>
              <p>Wir bauen, testen auf allen Geräten und integrieren Formulare, Terminbuchung und SEO-Grundlagen. Sie haben jederzeit Einblick.</p>
            </div>
          </div>
          <div class="prozess-step reveal" data-delay="0.4">
            <div class="step-number mono text-amber">04</div>
            <div class="step-content">
              <h3>Launch und Weiterbetreuung</h3>
              <p>Ihre Website geht live. Wir schulen Sie ein, übergeben alle Zugänge und bleiben als Ansprechpartner. Auf Wunsch erweitern wir schrittweise mit KI-Funktionen.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section-padding" id="faq">
      <div class="container">
        <div class="section-label reveal">Häufige Fragen</div>
        <h2 class="reveal" data-delay="0.1">Was Sie wissen wollen, bevor Sie anfragen.</h2>
        <div class="faq-list">
          <details class="faq-item card reveal" data-delay="0.1">
            <summary class="faq-question">Was kostet Webdesign in München?</summary>
            <div class="faq-answer">
              <p>Ehrliche Antwort: Ab ca. 2.000 € für eine einfache Website. Komplexere Projekte mit mehr Seiten, individuellen Funktionen und KI-Integration kosten 5.000 € und mehr. Wir nennen Ihnen im Erstgespräch eine konkrete Zahl — ohne Luftblasen und ohne versteckte Kosten.</p>
            </div>
          </details>
          <details class="faq-item card reveal" data-delay="0.15">
            <summary class="faq-question">Wie lange dauert eine Website?</summary>
            <div class="faq-answer">
              <p>3 bis 6 Wochen vom Kick-off bis zum Launch. Was die Dauer bestimmt: Wie schnell Sie Inhalte liefern und Feedback geben — und wie komplex das Projekt ist. Wir sind bekannt dafür, Termine einzuhalten.</p>
            </div>
          </details>
          <details class="faq-item card reveal" data-delay="0.2">
            <summary class="faq-question">Können Sie persönlich vorbeikommen?</summary>
            <div class="faq-answer">
              <p>Ja. Wir kommen in München und im Umland persönlich vorbei — das ist unser Standard, keine Ausnahme. Außerhalb von München (Landshut, Augsburg, Ingolstadt) auch möglich. Erstgespräch auf Wunsch auch per Video.</p>
            </div>
          </details>
          <details class="faq-item card reveal" data-delay="0.25">
            <summary class="faq-question">Was ist inklusive?</summary>
            <div class="faq-answer">
              <p>Strategie und Konzept, responsives Design, SEO-Grundoptimierung, DSGVO-konforme Cookie-Lösung, Kontaktformular, Hosting-Beratung und Einschulung. KI-Funktionen wie Chatbot oder Terminbuchung können direkt integriert oder später ergänzt werden.</p>
            </div>
          </details>
        </div>

        <script type="application/ld+json" is:inline>
        {
          "@context": "https://schema.org",
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "Was kostet Webdesign in München?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Ab ca. 2.000 Euro für eine einfache Website. Komplexere Projekte kosten 5.000 Euro und mehr."
              }
            },
            {
              "@type": "Question",
              "name": "Wie lange dauert eine Website?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "3 bis 6 Wochen vom Kick-off bis zum Launch."
              }
            },
            {
              "@type": "Question",
              "name": "Können Sie persönlich vorbeikommen?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Ja. Wir kommen in München und im Umland persönlich vorbei. Das ist unser Standard."
              }
            },
            {
              "@type": "Question",
              "name": "Was ist inklusive?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Strategie und Konzept, responsives Design, SEO-Grundoptimierung, DSGVO-konforme Cookie-Lösung, Kontaktformular, Hosting-Beratung und Einschulung."
              }
            }
          ]
        }
        </script>
      </div>
    </section>

    <!-- CTA -->
    <section class="section-padding cta-section" id="kontakt">
      <div class="container">
        <div class="cta-block reveal">
          <div class="section-label">Nächster Schritt</div>
          <h2>Kostenloses Erstgespräch — persönlich in München oder per Video.</h2>
          <p>30 Minuten. Wir schauen uns Ihre aktuelle Website an, hören was Sie brauchen — und sagen Ihnen ehrlich, was möglich ist.</p>
          <div class="cta-actions">
            <a href="mailto:hallo@botmanufactory.de" class="btn-primary">Termin anfragen</a>
            <a href="/website-relaunch" class="btn-secondary">Mehr zum Website Relaunch →</a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .leistung-hero {
    position: relative;
    padding-top: 160px;
    overflow: hidden;
  }

  .hero-bg { position: absolute; inset: 0; pointer-events: none; }

  .hero-glow-1 {
    position: absolute;
    top: -100px;
    right: -100px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255,184,0,0.1) 0%, transparent 70%);
    animation: mesh-drift-1 12s ease-in-out infinite;
  }

  .hero-glow-2 {
    position: absolute;
    bottom: -100px;
    left: -100px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(0,212,255,0.06) 0%, transparent 70%);
    animation: mesh-drift-2 16s ease-in-out infinite;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 24px;
    font-family: var(--font-heading);
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    animation: pulse-glow 2s ease-in-out infinite;
    display: inline-block;
  }

  .hero-sub {
    font-size: clamp(18px, 2vw, 22px);
    color: var(--color-text-secondary);
    max-width: 640px;
    margin: 24px 0 40px;
    line-height: 1.6;
  }

  .hero-ctas { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 40px; }
  .hero-trust { display: flex; gap: 24px; flex-wrap: wrap; }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  .section-label {
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 16px;
  }

  /* Regional */
  .regional-section {
    background: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .regional-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .regional-text h2 { margin-bottom: 20px; }

  .regional-text p {
    color: var(--color-text-secondary);
    margin-bottom: 16px;
    font-size: 17px;
  }

  .locations-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 8px;
  }

  .location-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 16px;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: 10px;
  }

  .loc-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-primary);
    flex-shrink: 0;
    margin-top: 6px;
  }

  .loc-dot.loc-secondary {
    background: var(--color-border-strong);
  }

  .loc-name {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 16px;
    margin-bottom: 2px;
  }

  .loc-desc {
    font-size: 13px;
    color: var(--color-text-muted);
  }

  /* Features */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .feature-card { padding: 32px; }
  .feature-icon { margin-bottom: 20px; }
  .feature-card h3 { font-size: 18px; margin-bottom: 12px; }

  .feature-card p {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  /* Vergleich */
  .vergleich-section {
    background: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .vergleich-table {
    margin-top: 48px;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
  }

  .vt-header {
    display: grid;
    grid-template-columns: 180px 1fr 1fr;
    background: var(--color-bg-subtle);
    border-bottom: 1px solid var(--color-border);
  }

  .vt-row {
    display: grid;
    grid-template-columns: 180px 1fr 1fr;
    border-bottom: 1px solid var(--color-border);
  }

  .vt-row:last-child { border-bottom: none; }

  .vt-col-label,
  .vt-col {
    padding: 16px 20px;
    font-size: 15px;
    border-right: 1px solid var(--color-border);
  }

  .vt-col:last-child { border-right: none; }

  .vt-col-label {
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .vt-col {
    color: var(--color-text-secondary);
  }

  .vt-col-us {
    font-weight: 600;
  }

  .vt-header .vt-col-label { font-size: 11px; }
  .vt-header .vt-col { font-family: var(--font-heading); font-weight: 700; font-size: 14px; color: var(--color-text-primary); }
  .vt-header .vt-col-us { color: var(--color-primary); }

  /* Prozess */
