---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Voice Agent — KI-Sprachassistent für Ihr Unternehmen | botmanufactory"
  description="Voice Agents die telefonieren, Outbound-Calls führen und Aufgaben per Sprache erledigen. Die nächste Stufe nach dem Telefonassistenten. Jetzt informieren."
  canonical="https://botmanufactory.de/voice-agent"
>
  <Nav />
  <main>

    <!-- Hero -->
    <section class="leistung-hero section-padding">
      <div class="hero-bg" aria-hidden="true">
        <div class="hero-glow-1"></div>
        <div class="hero-glow-2"></div>
      </div>
      <div class="container">
        <div class="hero-badge reveal">
          <span class="badge-dot" aria-hidden="true"></span>
          Voice Agent
        </div>
        <h1 class="reveal" data-delay="0.1">
          Voice Agent —<br />
          <span class="text-amber">KI die für Sie telefoniert.</span>
        </h1>
        <p class="hero-sub reveal" data-delay="0.2">
          Der nächste Schritt nach dem Telefonassistenten: Voice Agents führen auch ausgehende Anrufe — für Terminbestätigungen, Follow-ups und Kundenzufriedenheitsabfragen. Vollautomatisch.
        </p>
        <div class="hero-ctas reveal" data-delay="0.3">
          <a href="#kontakt" class="btn-primary">Kostenlose Beratung</a>
          <a href="#unterschied" class="btn-secondary">Was ist der Unterschied?</a>
        </div>
        <div class="hero-trust reveal" data-delay="0.4">
          <span class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/><polyline points="22 4 12 14.01 9 11.01" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Inbound & Outbound
          </span>
          <span class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/><polyline points="22 4 12 14.01 9 11.01" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            DSGVO-konform
          </span>
          <span class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/><polyline points="22 4 12 14.01 9 11.01" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            In Workflows integrierbar
          </span>
        </div>
      </div>
    </section>

    <!-- Unterschied -->
    <section class="section-padding" id="unterschied">
      <div class="container">
        <div class="section-label reveal">Telefonassistent vs. Voice Agent</div>
        <h2 class="reveal" data-delay="0.1">
          Was ist der Unterschied?
        </h2>
        <div class="vergleich-grid">
          <div class="vergleich-card card reveal" data-delay="0.1">
            <div class="vc-header">
              <div class="vc-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" stroke="var(--color-text-secondary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div class="vc-title">KI Telefonassistent</div>
            </div>
            <ul class="vc-list">
              <li>Nimmt eingehende Anrufe entgegen</li>
              <li>Beantwortet Fragen zu Ihrem Unternehmen</li>
              <li>Bucht Termine in Ihren Kalender</li>
              <li>Leitet bei Bedarf an Mitarbeiter weiter</li>
            </ul>
            <div class="vc-cta">
              <a href="/ki-telefonassistent" class="btn-secondary">Zum Telefonassistenten →</a>
            </div>
          </div>
          <div class="vergleich-card card card-featured reveal" data-delay="0.2">
            <div class="vc-header">
              <div class="vc-icon vc-icon-amber" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div class="vc-title">Voice Agent</div>
              <div class="vc-badge">Mehr Möglichkeiten</div>
            </div>
            <ul class="vc-list">
              <li>Alles was der Telefonassistent kann, plus:</li>
              <li class="highlight">Ausgehende Anrufe (Outbound)</li>
              <li class="highlight">Komplexere Dialoge und Entscheidungslogik</li>
              <li class="highlight">Integration in bestehende Workflows und CRM</li>
              <li class="highlight">Anruf-Kampagnen für mehrere Kontakte gleichzeitig</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Use Cases -->
    <section class="section-padding usecases-section">
      <div class="container">
        <div class="section-label reveal">Anwendungsbeispiele</div>
        <h2 class="reveal" data-delay="0.1">
          Was ein Voice Agent für Sie übernehmen kann.
        </h2>
        <div class="usecases-grid">
          <div class="usecase-card card reveal" data-delay="0.1">
            <div class="uc-num mono text-amber">01</div>
            <h3>Terminbestätigungen</h3>
            <p>Der Voice Agent ruft Ihre Kunden automatisch an und bestätigt gebuchte Termine — oder bucht sie um, wenn nötig. Kein No-Show mehr ohne Vorwarnung.</p>
            <div class="uc-example">Beispiel: "Guten Tag, ich rufe im Auftrag der Zahnarztpraxis Dr. Koch an. Ihr Termin am Dienstag um 10 Uhr ist bestätigt. Alles gut so?"</div>
          </div>
          <div class="usecase-card card reveal" data-delay="0.15">
            <div class="uc-num mono text-amber">02</div>
            <h3>Kundenzufriedenheit abfragen</h3>
            <p>Nach einem Auftrag oder einer Behandlung ruft der Agent an und fragt kurz nach dem Feedback. Die Ergebnisse werden automatisch ausgewertet.</p>
            <div class="uc-example">Beispiel: "Guten Tag, war alles zu Ihrer Zufriedenheit? Falls nicht — was hätten wir besser machen können?"</div>
          </div>
          <div class="usecase-card card reveal" data-delay="0.2">
            <div class="uc-num mono text-amber">03</div>
            <h3>Angebots-Follow-up</h3>
            <p>Ein Angebot rausgeschickt und keine Reaktion? Der Agent ruft nach einer definierten Zeit an und hakt freundlich nach — ohne dass Ihre Mitarbeiter daran denken müssen.</p>
            <div class="uc-example">Beispiel: "Guten Tag, haben Sie unser Angebot erhalten? Gibt es noch offene Fragen?"</div>
          </div>
          <div class="usecase-card card reveal" data-delay="0.25">
            <div class="uc-num mono text-amber">04</div>
            <h3>Mahnwesen Erstkontakt</h3>
            <p>Freundliche Erinnerung an überfällige Rechnungen — per Anruf, nicht per Brief. Deutlich effektiver und schneller als der Postweg.</p>
            <div class="uc-example">Beispiel: "Guten Tag, wir haben festgestellt, dass eine Rechnung vom 15. März noch offen ist. Können wir kurz klären, ob es einen Grund dafür gibt?"</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="section-padding">
      <div class="container">
        <div class="section-label reveal">Was Voice Agents können</div>
        <h2 class="reveal" data-delay="0.1">Technisch weiterentwickelt — für komplexere Aufgaben.</h2>
        <div class="features-grid">
          <div class="feature-card card reveal" data-delay="0.1">
            <div class="feature-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><polyline points="17 1 21 5 17 9" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M3 11V9a4 4 0 0 1 4-4h14" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M7 23l-4-4 4-4M21 13v2a4 4 0 0 1-4 4H3" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3>Outbound-Anrufe</h3>
            <p>Der Agent ruft proaktiv an — nicht nur auf eingehende Anrufe wartend. Für Bestätigungen, Follow-ups und Kampagnen.</p>
          </div>
          <div class="feature-card card reveal" data-delay="0.15">
            <div class="feature-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="var(--color-primary)" stroke-width="1.5"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><line x1="12" y1="17" x2="12.01" y2="17" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round"/></svg>
            </div>
            <h3>Komplexe Dialoge</h3>
            <p>Voice Agents können bedingte Logik verarbeiten: Je nach Antwort folgt ein anderer Gesprächspfad. Für nuancierte Gespräche jenseits einfacher FAQ.</p>
          </div>
          <div class="feature-card card reveal" data-delay="0.2">
            <div class="feature-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><rect x="2" y="3" width="20" height="14" rx="2" stroke="var(--color-primary)" stroke-width="1.5"/><path d="M8 21h8M12 17v4" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <h3>CRM-Integration</h3>
            <p>Ergebnisse aus Anrufen fließen direkt ins CRM — Notizen, Status-Updates, neue Termine. Kein manuelles Nachtragen.</p>
          </div>
          <div class="feature-card card reveal" data-delay="0.25">
            <div class="feature-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M22 12h-4l-3 9L9 3l-3 9H2" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3>Echtzeit-Analyse</h3>
            <p>Jedes Gespräch wird transkribiert und analysiert. Sentiment, Schlüsselwörter, Ergebnis — alles im Dashboard einsehbar.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Prozess -->
    <section class="section-padding prozess-section">
      <div class="container">
        <div class="section-label reveal">Zusammenarbeit</div>
        <h2 class="reveal" data-delay="0.1">Wie wir einen Voice Agent für Sie aufbauen.</h2>
        <div class="prozess-steps">
          <div class="prozess-step reveal" data-delay="0.1">
            <div class="step-number mono text-amber">01</div>
            <div class="step-content">
              <h3>Zieldefinition</h3>
              <p>Was soll der Agent tun? Welche Workflows sollen automatisiert werden? Wer sind die Angerufenen, und welches Ergebnis wollen wir pro Anruf erreichen?</p>
            </div>
          </div>
          <div class="prozess-step reveal" data-delay="0.2">
            <div class="step-number mono text-amber">02</div>
            <div class="step-content">
              <h3>Skript & Logik</h3>
              <p>Wir entwickeln die Gesprächslogik: Einstieg, mögliche Antworten, Verzweigungen und Abschluss. Sie freigeben, wir bauen.</p>
            </div>
          </div>
          <div class="prozess-step reveal" data-delay="0.3">
            <div class="step-number mono text-amber">03</div>
            <div class="step-content">
              <h3>Test & Feinschliff</h3>
              <p>Wir testen den Agenten mit echten Testanrufen, passen Timing, Formulierungen und Eskalationspfade an. Erst wenn alles stimmt, geht er live.</p>
            </div>
          </div>
          <div class="prozess-step reveal" data-delay="0.4">
            <div class="step-number mono text-amber">04</div>
            <div class="step-content">
              <h3>Live-Betrieb</h3>
              <p>Der Agent läuft. Alle Anrufergebnisse sind im Dashboard einsehbar. Wir optimieren laufend auf Basis echter Gespräche.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section-padding" id="faq">
      <div class="container">
        <div class="section-label reveal">Häufige Fragen</div>
        <h2 class="reveal" data-delay="0.1">Ihre Fragen zum Voice Agent.</h2>
        <div class="faq-list">
          <details class="faq-item card reveal" data-delay="0.1">
            <summary class="faq-question">Was ist der Unterschied zwischen Voice Agent und Telefonassistent?</summary>
            <div class="faq-answer">
              <p>Der KI Telefonassistent nimmt eingehende Anrufe entgegen — er reagiert. Ein Voice Agent kann zusätzlich ausgehend anrufen — er handelt proaktiv. Außerdem kann der Voice Agent komplexere Gesprächslogiken verwalten und tiefer in Ihre bestehenden Systeme integriert werden.</p>
            </div>
          </details>
          <details class="faq-item card reveal" data-delay="0.15">
            <summary class="faq-question">Kann der Voice Agent auch anrufen?</summary>
            <div class="faq-answer">
              <p>Ja — das ist der zentrale Unterschied zum Telefonassistenten. Der Voice Agent ruft auf Basis von Triggern an: ein bestätigter Termin, eine überfällige Rechnung, ein versendetes Angebot. Sie definieren die Regeln, der Agent handelt automatisch.</p>
            </div>
          </details>
          <details class="faq-item card reveal" data-delay="0.2">
            <summary class="faq-question">Wie menschlich klingt das?</summary>
            <div class="faq-answer">
              <p>Sehr natürlich. Moderne Voice-KI hat den Roboter-Sound hinter sich gelassen. Pausen, Betonungen, Reaktionen auf das Gesagte — das klingt nach einem echten Gespräch. Wir zeigen Ihnen im Erstgespräch Beispiele und können die Stimme an Ihr Unternehmen anpassen.</p>
            </div>
          </details>
          <details class="faq-item card reveal" data-delay="0.25">
            <summary class="faq-question">Ist das bei Outbound-Calls DSGVO-konform?</summary>
            <div class="faq-answer">
              <p>Ja — unter bestimmten Voraussetzungen. Outbound-Anrufe sind zulässig, wenn eine bestehende Kundenbeziehung besteht und der Anruf im legitimen Interesse liegt (z.B. Terminbestätigung, Rechnungserinnerung). Wir beraten Sie dabei rechtlich und technisch. Für Kaltakquise ist der Voice Agent nicht geeignet.</p>
            </div>
          </details>
        </div>

        <script type="application/ld+json" is:inline>
        {
          "@context": "https://schema.org",
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "Was ist der Unterschied zwischen Voice Agent und Telefonassistent?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Der KI Telefonassistent nimmt eingehende Anrufe entgegen. Ein Voice Agent kann zusätzlich ausgehend anrufen und komplexere Gesprächslogiken verwalten."
              }
            },
            {
              "@type": "Question",
              "name": "Kann der Voice Agent auch anrufen?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Ja. Der Voice Agent ruft auf Basis von Triggern an: bestätigte Termine, überfällige Rechnungen, versendete Angebote."
              }
            },
            {
              "@type": "Question",
              "name": "Wie menschlich klingt das?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Sehr natürlich. Moderne Voice-KI klingt nach einem echten Gespräch — mit Pausen, Betonungen und Reaktionen auf das Gesagte."
              }
            },
            {
              "@type": "Question",
              "name": "Ist das bei Outbound-Calls DSGVO-konform?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Ja unter bestimmten Voraussetzungen. Outbound-Anrufe sind zulässig bei bestehender Kundenbeziehung und legitimen Interesse wie Terminbestätigungen oder Rechnungserinnerungen."
              }
            }
          ]
        }
        </script>
      </div>
    </section>

    <!-- CTA -->
    <section class="section-padding cta-section" id="kontakt">
      <div class="container">
        <div class="cta-block reveal">
          <div class="section-label">Nächster Schritt</div>
          <h2>Voice Agent — wir zeigen Ihnen, was möglich ist.</h2>
          <p>Kostenloses 30-Minuten-Gespräch. Wir analysieren Ihre Prozesse und zeigen, wo ein Voice Agent den größten Hebel hat.</p>
          <div class="cta-actions">
            <a href="mailto:hallo@botmanufactory.de" class="btn-primary">Beratungsgespräch anfragen</a>
            <a href="/ki-automatisierung" class="btn-secondary">Auch interessant: KI Automatisierung →</a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .leistung-hero {
    position: relative;
    padding-top: 160px;
    overflow: hidden;
  }

  .hero-bg { position: absolute; inset: 0; pointer-events: none; }

  .hero-glow-1 {
    position: absolute;
    top: -100px;
    right: -100px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255,184,0,0.1) 0%, transparent 70%);
    animation: mesh-drift-1 12s ease-in-out infinite;
  }

  .hero-glow-2 {
    position: absolute;
    bottom: -100px;
    left: -100px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(0,212,255,0.06) 0%, transparent 70%);
    animation: mesh-drift-2 16s ease-in-out infinite;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 24px;
    font-family: var(--font-heading);
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    animation: pulse-glow 2s ease-in-out infinite;
    display: inline-block;
  }

  .hero-sub {
    font-size: clamp(18px, 2vw, 22px);
    color: var(--color-text-secondary);
    max-width: 640px;
    margin: 24px 0 40px;
    line-height: 1.6;
  }

  .hero-ctas { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 40px; }

  .hero-trust { display: flex; gap: 24px; flex-wrap: wrap; }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  .section-label {
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 16px;
  }

  /* Vergleich */
  .vergleich-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 48px;
  }

  .vergleich-card { padding: 40px; }

  .card-featured {
    border-color: rgba(255,184,0,0.4);
    background: linear-gradient(135deg, var(--color-bg-elevated) 0%, rgba(255,184,0,0.03) 100%);
  }

  .vc-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .vc-icon {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .vc-icon-amber {
    background: rgba(255,184,0,0.1);
    border-color: rgba(255,184,0,0.2);
  }

  .vc-title {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 700;
  }

  .vc-badge {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-primary);
    background: rgba(255,184,0,0.1);
    border: 1px solid rgba(255,184,0,0.2);
    border-radius: 4px;
    padding: 3px 8px;
  }

  .vc-list {
    list-style: none;
    padding: 0;
    margin: 0 0 32px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .vc-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 16px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .vc-list li::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-border-strong);
    flex-shrink: 0;
    margin-top: 8px;
  }

  .vc-list li.highlight {
    color: var(--color-text-primary);
  }

  .vc-list li.highlight::before {
    background: var(--color-primary);
  }

  /* Use Cases */
  .usecases-section {
    background: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .usecases-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 48px;
  }

  .usecase-card { padding: 36px; }

  .uc-num {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.1em;
    margin-bottom: 12px;
  }

  .usecase-card h3 { font-size: 22px; margin-bottom: 12px; }

  .usecase-card p {
    color: var(--color-text-secondary);
    font-size: 16px;
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .uc-example {
    font-size: 14px;
    color: var(--color-text-muted);
    font-style: italic;
    border-left: 2px solid rgba(255,184,0,0.3);
    padding-left: 16px;
    line-height: 1.6;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 48px;
