---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Website Relaunch Agentur München | botmanufactory"
  description="Website Relaunch der Anfragen bringt statt abschreckt. Für Handwerker, Arztpraxen und Mittelstand. Fertig in 3-6 Wochen. Persönlich in München und Bayern."
  canonical="https://botmanufactory.de/website-relaunch"
>
  <Nav />
  <main>

    <!-- Hero -->
    <section class="leistung-hero section-padding">
      <div class="hero-bg" aria-hidden="true">
        <div class="hero-glow-1"></div>
        <div class="hero-glow-2"></div>
      </div>
      <div class="container">
        <div class="hero-badge reveal">
          <span class="badge-dot" aria-hidden="true"></span>
          Website Relaunch
        </div>
        <h1 class="reveal" data-delay="0.1">
          Website Relaunch —<br />
          <span class="text-amber">Ihre neue digitale Visitenkarte.</span>
        </h1>
        <p class="hero-sub reveal" data-delay="0.2">
          Ihre Website von 2018 kostet Sie täglich Kunden — nicht durch das, was sie zeigt, sondern durch das, was sie nicht zeigt. Wir bauen eine neue, die wirklich Anfragen bringt. In 3 bis 6 Wochen. Persönlich in München und Bayern.
        </p>
        <div class="hero-ctas reveal" data-delay="0.3">
          <a href="#kontakt" class="btn-primary">Kostenlose Website-Analyse</a>
          <a href="#was-inkludiert" class="btn-secondary">Was ist inklusive?</a>
        </div>
        <div class="hero-trust reveal" data-delay="0.4">
          <span class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/><polyline points="22 4 12 14.01 9 11.01" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            3–6 Wochen Umsetzung
          </span>
          <span class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/><polyline points="22 4 12 14.01 9 11.01" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            DSGVO-konform
          </span>
          <span class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/><polyline points="22 4 12 14.01 9 11.01" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Persönlich vor Ort in Bayern
          </span>
        </div>
      </div>
    </section>

    <!-- Problem -->
    <section class="section-padding">
      <div class="container">
        <div class="section-label reveal">Warum ein Relaunch?</div>
        <h2 class="reveal" data-delay="0.1">
          Ihre alte Website ist nicht neutral —<br />
          <span class="text-amber">sie schadet aktiv.</span>
        </h2>
        <div class="problem-grid">
          <div class="problem-card card reveal" data-delay="0.1">
            <div class="problem-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="5" y="2" width="14" height="20" rx="2" stroke="var(--color-error)" stroke-width="1.5"/><line x1="12" y1="18" x2="12.01" y2="18" stroke="var(--color-error)" stroke-width="2" stroke-linecap="round"/></svg>
            </div>
            <h3>Nicht mobiloptimiert</h3>
            <p>Über 70% Ihrer potenziellen Kunden besuchen Ihre Website vom Smartphone. Wenn sie dort schlecht aussieht oder nicht funktioniert, sind sie weg — in 3 Sekunden.</p>
          </div>
          <div class="problem-card card reveal" data-delay="0.2">
            <div class="problem-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="var(--color-error)" stroke-width="1.5"/><path d="M12 8v4l3 3" stroke="var(--color-error)" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <h3>Lädt zu langsam</h3>
            <p>Jede Sekunde Ladezeit kostet Besucher. Ab 3 Sekunden bricht die Hälfte ab. Alte Websites mit unkomprimierten Bildern und veraltetem Code laden oft 5 bis 10 Sekunden.</p>
          </div>
          <div class="problem-card card reveal" data-delay="0.3">
            <div class="problem-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" stroke="var(--color-error)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><line x1="12" y1="9" x2="12" y2="13" stroke="var(--color-error)" stroke-width="1.5" stroke-linecap="round"/><line x1="12" y1="17" x2="12.01" y2="17" stroke="var(--color-error)" stroke-width="2" stroke-linecap="round"/></svg>
            </div>
            <h3>Kein SSL, kein Google-Ranking</h3>
            <p>Ohne HTTPS zeigt Chrome "Nicht sicher" — und Google bestraft fehlende Sicherheit mit schlechterem Ranking. Ihre Mitbewerber mit modernen Websites werden gefunden, Sie nicht.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Was inkludiert -->
    <section class="section-padding inkludiert-section" id="was-inkludiert">
      <div class="container">
        <div class="section-label reveal">Leistungsumfang</div>
        <h2 class="reveal" data-delay="0.1">Was im Relaunch enthalten ist.</h2>
        <div class="inkludiert-grid">
          <div class="inkludiert-item reveal" data-delay="0.1">
            <div class="ii-check" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><polyline points="20 6 9 17 4 12" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div>
              <div class="ii-title">Strategie und Konzept</div>
              <div class="ii-desc">Welche Seiten brauchen Sie? Welche Botschaft soll ankommen? Wer sind Ihre Wunschkunden — und wie entscheiden die?</div>
            </div>
          </div>
          <div class="inkludiert-item reveal" data-delay="0.15">
            <div class="ii-check" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><polyline points="20 6 9 17 4 12" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div>
              <div class="ii-title">Modernes responsives Design</div>
              <div class="ii-desc">Desktop, Tablet, Smartphone — sieht überall gut aus. Kein Template, sondern ein Design das zu Ihrem Unternehmen passt.</div>
            </div>
          </div>
          <div class="inkludiert-item reveal" data-delay="0.2">
            <div class="ii-check" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><polyline points="20 6 9 17 4 12" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div>
              <div class="ii-title">SEO-Grundoptimierung</div>
              <div class="ii-desc">Technisches SEO, Meta-Tags, strukturierte Daten — damit Google Ihre neue Website sofort richtig einordnen kann.</div>
            </div>
          </div>
          <div class="inkludiert-item reveal" data-delay="0.25">
            <div class="ii-check" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><polyline points="20 6 9 17 4 12" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div>
              <div class="ii-title">Kontaktformular und Terminbuchung</div>
              <div class="ii-desc">DSGVO-konformes Formular und auf Wunsch direkte Terminbuchung — damit jeder Besucher sofort Kontakt aufnehmen kann.</div>
            </div>
          </div>
          <div class="inkludiert-item reveal" data-delay="0.3">
            <div class="ii-check" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><polyline points="20 6 9 17 4 12" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div>
              <div class="ii-title">DSGVO-konforme Cookie-Lösung</div>
              <div class="ii-desc">Professionelles Cookie-Banner, Datenschutzerklärung und Impressum — rechtssicher, ohne nervige Popup-Flut.</div>
            </div>
          </div>
          <div class="inkludiert-item reveal" data-delay="0.35">
            <div class="ii-check" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><polyline points="20 6 9 17 4 12" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div>
              <div class="ii-title">Hosting-Beratung und Migration</div>
              <div class="ii-desc">Wir empfehlen das richtige Hosting für Ihr Budget und Ihre Anforderungen — und migrieren bestehende Inhalte wo sinnvoll.</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Prozess -->
    <section class="section-padding prozess-section">
      <div class="container">
        <div class="section-label reveal">Ablauf</div>
        <h2 class="reveal" data-delay="0.1">Von der Analyse bis zum Launch — in 4 Schritten.</h2>
        <div class="prozess-timeline">
          <div class="prozess-step reveal" data-delay="0.1">
            <div class="step-number mono text-amber">01</div>
            <div class="step-content">
              <h3>Analyse und Strategie</h3>
              <p>Wir schauen uns Ihre aktuelle Website, Ihre Mitbewerber und Ihre Zielgruppe an. Dann definieren wir gemeinsam: Was soll die neue Website erreichen? Wer soll sie ansprechen?</p>
              <div class="step-duration">ca. 1 Woche</div>
            </div>
          </div>
          <div class="prozess-step reveal" data-delay="0.2">
            <div class="step-number mono text-amber">02</div>
            <div class="step-content">
              <h3>Konzept und Design</h3>
              <p>Wir erstellen Wireframes und ein Design-Konzept — Sie sehen und freigeben, bevor Programmierung beginnt. Keine bösen Überraschungen am Ende.</p>
              <div class="step-duration">ca. 1–2 Wochen</div>
            </div>
          </div>
          <div class="prozess-step reveal" data-delay="0.3">
            <div class="step-number mono text-amber">03</div>
            <div class="step-content">
              <h3>Umsetzung und Befüllung</h3>
              <p>Wir bauen die Website, befüllen sie mit Ihren Inhalten (oder helfen beim Texten), und testen auf allen Geräten. Sie haben jederzeit Einblick.</p>
              <div class="step-duration">ca. 2–3 Wochen</div>
            </div>
          </div>
          <div class="prozess-step reveal" data-delay="0.4">
            <div class="step-number mono text-amber">04</div>
            <div class="step-content">
              <h3>Launch und Übergabe</h3>
              <p>Die neue Website geht live. Wir übergeben Zugänge, schulen Sie ein und bleiben als Ansprechpartner. Bei Bedarf bauen wir direkt KI-Funktionen ein.</p>
              <div class="step-duration">Launch-Tag</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- KI-bereit -->
    <section class="section-padding">
      <div class="container">
        <div class="ki-bereit-block reveal">
          <div class="kb-text">
            <div class="section-label">Das Besondere bei Botmanufactory</div>
            <h2>Jede Website ist KI-bereit.</h2>
            <p>Wir bauen keine Website, die nach einem Jahr wieder veraltet. Jeder Relaunch wird so konzipiert, dass KI-Funktionen nahtlos ergänzt werden können — KI Chatbot, Terminbuchung, Voice Agent. Das ist unser Einstiegsprodukt, kein Endpunkt.</p>
            <div class="kb-links">
              <a href="/ki-chatbot" class="btn-secondary">KI Chatbot hinzufügen →</a>
              <a href="/ki-automatisierung" class="btn-secondary">Prozesse automatisieren →</a>
            </div>
          </div>
          <div class="kb-quote reveal" data-delay="0.2">
            <blockquote>
              "Wir bauen zuerst Ihre Website. Dann automatisieren wir Ihr Unternehmen."
            </blockquote>
            <cite>Michael Segl, Gründer Botmanufactory</cite>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section-padding" id="faq">
      <div class="container">
        <div class="section-label reveal">Häufige Fragen</div>
        <h2 class="reveal" data-delay="0.1">Was Sie wissen wollen, bevor Sie anfragen.</h2>
        <div class="faq-list">
          <details class="faq-item card reveal" data-delay="0.1">
            <summary class="faq-question">Was kostet ein Website Relaunch?</summary>
            <div class="faq-answer">
              <p>Das hängt vom Umfang ab: Anzahl der Seiten, individuelle Funktionen, Texterstellung. Einfache Websites starten ab ca. 2.000 €, komplexere Projekte mit mehr Seiten und Funktionen können 5.000 € und mehr kosten. Wir nennen Ihnen im kostenlosen Erstgespräch eine ehrliche Zahl — keine versteckten Kosten.</p>
            </div>
          </details>
          <details class="faq-item card reveal" data-delay="0.15">
            <summary class="faq-question">Wie lange dauert das?</summary>
            <div class="faq-answer">
              <p>In der Regel 3 bis 6 Wochen vom Kick-off bis zum Launch. Was die Dauer beeinflusst: Wie schnell Sie Inhalte und Feedback liefern, und wie komplex die Website ist. Wir halten unsere Zeitversprechen — und kommunizieren früh, wenn sich etwas ändert.</p>
            </div>
          </details>
          <details class="faq-item card reveal" data-delay="0.2">
            <summary class="faq-question">Was passiert mit meiner alten Website?</summary>
            <div class="faq-answer">
              <p>Sie läuft bis zum Launch der neuen Website normal weiter — kein Ausfall. Bestehende SEO-Rankings werden durch saubere Weiterleitungen geschützt. Wichtige Inhalte migrieren wir wo sinnvoll.</p>
            </div>
          </details>
          <details class="faq-item card reveal" data-delay="0.25">
            <summary class="faq-question">Brauche ich eine neue Domain?</summary>
            <div class="faq-answer">
              <p>Nein. Wir bauen auf Ihrer bestehenden Domain — oder helfen Ihnen beim Wechsel, falls gewünscht. Ihre E-Mail-Adressen bleiben erhalten.</p>
            </div>
          </details>
          <details class="faq-item card reveal" data-delay="0.3">
            <summary class="faq-question">Kann ich die Website nach dem Launch selbst pflegen?</summary>
            <div class="faq-answer">
              <p>Ja. Wir bauen ein einfaches CMS ein, damit Sie Texte und Bilder selbst aktualisieren können — ohne Programmierkenntnisse. Alternativ übernehmen wir die laufende Pflege im Rahmen eines Wartungsvertrags.</p>
            </div>
          </details>
        </div>

        <script type="application/ld+json" is:inline>
        {
          "@context": "https://schema.org",
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "Was kostet ein Website Relaunch?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Einfache Websites starten ab ca. 2.000 Euro, komplexere Projekte können 5.000 Euro und mehr kosten."
              }
            },
            {
              "@type": "Question",
              "name": "Wie lange dauert das?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "In der Regel 3 bis 6 Wochen vom Kick-off bis zum Launch."
              }
            },
            {
              "@type": "Question",
              "name": "Was passiert mit meiner alten Website?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Sie läuft bis zum Launch der neuen Website normal weiter. Bestehende SEO-Rankings werden durch saubere Weiterleitungen geschützt."
              }
            },
            {
              "@type": "Question",
              "name": "Brauche ich eine neue Domain?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Nein. Wir bauen auf Ihrer bestehenden Domain oder helfen beim Wechsel falls gewünscht."
              }
            },
            {
              "@type": "Question",
              "name": "Kann ich die Website nach dem Launch selbst pflegen?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Ja. Wir bauen ein einfaches CMS ein damit Sie Texte und Bilder selbst aktualisieren können."
              }
            }
          ]
        }
        </script>
      </div>
    </section>

    <!-- CTA -->
    <section class="section-padding cta-section" id="kontakt">
      <div class="container">
        <div class="cta-block reveal">
          <div class="section-label">Nächster Schritt</div>
          <h2>Kostenlose Website-Analyse — unverbindlich, direkt auf den Punkt.</h2>
          <p>30 Minuten. Wir schauen uns Ihre aktuelle Website an und sagen Ihnen konkret, was geändert werden sollte — und was es bringt. Persönlich oder per Video.</p>
          <div class="cta-actions">
            <a href="mailto:hallo@botmanufactory.de" class="btn-primary">Analyse anfragen</a>
            <a href="/webdesign-muenchen" class="btn-secondary">Webdesign München →</a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .leistung-hero {
    position: relative;
    padding-top: 160px;
    overflow: hidden;
  }

  .hero-bg { position: absolute; inset: 0; pointer-events: none; }

  .hero-glow-1 {
    position: absolute;
    top: -100px;
    right: -100px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255,184,0,0.1) 0%, transparent 70%);
    animation: mesh-drift-1 12s ease-in-out infinite;
  }

  .hero-glow-2 {
    position: absolute;
    bottom: -100px;
    left: -100px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(0,212,255,0.06) 0%, transparent 70%);
    animation: mesh-drift-2 16s ease-in-out infinite;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 24px;
    font-family: var(--font-heading);
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    animation: pulse-glow 2s ease-in-out infinite;
    display: inline-block;
  }

  .hero-sub {
    font-size: clamp(18px, 2vw, 22px);
    color: var(--color-text-secondary);
    max-width: 640px;
    margin: 24px 0 40px;
    line-height: 1.6;
  }

  .hero-ctas { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 40px; }
  .hero-trust { display: flex; gap: 24px; flex-wrap: wrap; }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  .section-label {
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 16px;
  }

  .problem-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .problem-card { padding: 32px; }
  .problem-icon { margin-bottom: 20px; }
  .problem-card h3 { font-size: 20px; margin-bottom: 12px; }
  .problem-card p { font-size: 16px; color: var(--color-text-secondary); line-height: 1.7; margin: 0; }

  .inkludiert-section {
    background: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .inkludiert-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-top: 48px;
  }

  .inkludiert-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .ii-check {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(255,184,0,0.1);
    border: 1px solid rgba(255,184,0,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 4px;
  }

  .ii-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 18px;
    margin-bottom: 6px;
  }

  .ii-desc {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .prozess-section {
    background: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .prozess-timeline {
    margin-top: 48px;
    display: flex;
    flex-direction: column;
  }

  .prozess-step {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 32px;
    padding: 40px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .prozess-step:last-child { border-bottom: none; }

  .step-number {
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
    padding-top: 4px;
  }

  .step-content h3 { font-size: 22px; margin-bottom: 12px; }
  .step-content p { color: var(--color-text-secondary); margin: 0 0 12px; font-size: 16px; }

  .step-duration {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-primary);
    font-family: var(--font-heading);
  }

  /* KI-bereit */
  .ki-bereit-block {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 80px;
    align-items: center;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 64px;
  }

  .kb-text h2 { margin-bottom: 16px; }
  .kb-text p { color: var(--color-text-secondary); margin-bottom: 32px; }

  .kb-links { display: flex; gap: 12px; flex-wrap: wrap; }

  .kb-quote blockquote {
    font-size: clamp(20px, 2.5vw, 28px);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1.3;
    margin: 0 0 16px;
    position: relative;
    padding-left: 20px;
    border-left: 3px solid var(--color-primary);
