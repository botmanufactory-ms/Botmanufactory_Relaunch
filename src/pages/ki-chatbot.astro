---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="KI Chatbot für Ihre Website | botmanufactory München"
  description="KI Chatbot der rund um die Uhr Anfragen beantwortet, Leads qualifiziert und Termine bucht. DSGVO-konform, fertig in Wochen. Jetzt kostenlose Demo anfragen."
  canonical="https://botmanufactory.de/ki-chatbot"
>
  <Nav />
  <main>

    <!-- Hero -->
    <section class="leistung-hero section-padding">
      <div class="hero-bg" aria-hidden="true">
        <div class="hero-glow-1"></div>
        <div class="hero-glow-2"></div>
      </div>
      <div class="container">
        <div class="hero-badge reveal">
          <span class="badge-dot" aria-hidden="true"></span>
          KI Chatbot
        </div>
        <h1 class="reveal" data-delay="0.1">
          KI Chatbot für Ihre Website —<br />
          <span class="text-amber">der Mitarbeiter, der nie schläft.</span>
        </h1>
        <p class="hero-sub reveal" data-delay="0.2">
          Während Ihre Mitbewerber Anfragen über Nacht verlieren, antwortet Ihr KI Chatbot — präzise, freundlich und rund um die Uhr. Für Handwerker, Arztpraxen und Fitnessstudios.
        </p>
        <div class="hero-ctas reveal" data-delay="0.3">
          <a href="#kontakt" class="btn-primary">Kostenlose Demo anfragen</a>
          <a href="#leistungen" class="btn-secondary">Was kann der Chatbot?</a>
        </div>
        <div class="hero-trust reveal" data-delay="0.4">
          <span class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/><polyline points="22 4 12 14.01 9 11.01" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            DSGVO-konform
          </span>
          <span class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/><polyline points="22 4 12 14.01 9 11.01" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Fertig in 2–4 Wochen
          </span>
          <span class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/><polyline points="22 4 12 14.01 9 11.01" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Ab 99 € / Monat
          </span>
        </div>
      </div>
    </section>

    <!-- Problem -->
    <section class="section-padding" id="problem">
      <div class="container">
        <div class="section-label reveal">Das Problem</div>
        <h2 class="reveal" data-delay="0.1">
          Jede unbeantwortete Anfrage ist<br />
          <span class="text-amber">ein verlorener Kunde.</span>
        </h2>
        <div class="problem-grid">
          <div class="problem-card card reveal" data-delay="0.1">
            <div class="problem-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="var(--color-error)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3>Abends, nachts, am Wochenende</h3>
            <p>Genau dann suchen Menschen einen Handwerker oder buchen einen Arzttermin — wenn Ihr Telefon aus ist und niemand ans Postfach schaut.</p>
          </div>
          <div class="problem-card card reveal" data-delay="0.2">
            <div class="problem-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="var(--color-error)" stroke-width="1.5"/><path d="M12 8v4l3 3" stroke="var(--color-error)" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <h3>Langsame Reaktionszeiten</h3>
            <p>Wer auf eine Anfrage zwei Tage wartet, hat den Kunden längst verloren. Im Internet entscheidet Schnelligkeit.</p>
          </div>
          <div class="problem-card card reveal" data-delay="0.3">
            <div class="problem-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="var(--color-error)" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="var(--color-error)" stroke-width="1.5"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" stroke="var(--color-error)" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <h3>Immer dieselben Fragen</h3>
            <p>Öffnungszeiten, Preise, Parkplatz, Anfahrt — Ihre Mitarbeiter beantworten diese Fragen täglich, mehrfach. Das ist verschwendete Zeit.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Solution -->
    <section class="section-padding solution-section">
      <div class="container">
        <div class="solution-grid">
          <div class="solution-visual reveal">
            <div class="chat-mockup" aria-label="Chatbot-Demo">
              <div class="chat-header">
                <div class="chat-avatar" aria-hidden="true">B</div>
                <div>
                  <div class="chat-name">Botmanufactory KI</div>
                  <div class="chat-status">
                    <span class="status-dot" aria-hidden="true"></span>
                    Online
                  </div>
                </div>
              </div>
              <div class="chat-messages">
                <div class="msg msg-bot">Guten Abend! Wie kann ich Ihnen helfen?</div>
                <div class="msg msg-user">Haben Sie noch Termine diese Woche?</div>
                <div class="msg msg-bot">Ja, Mittwoch ab 14 Uhr wäre noch frei. Soll ich Ihnen direkt einen Termin reservieren?</div>
                <div class="msg msg-user">Gerne, für 16 Uhr.</div>
                <div class="msg msg-bot">Perfekt. Termin ist gebucht. Sie erhalten gleich eine Bestätigung per E-Mail.</div>
              </div>
              <div class="chat-time mono">22:47 Uhr · automatisch</div>
            </div>
          </div>
          <div class="solution-text">
            <div class="section-label reveal">Die Lösung</div>
            <h2 class="reveal" data-delay="0.1">Ein Chatbot, der wirklich versteht — und handelt.</h2>
            <p class="reveal" data-delay="0.2">Kein billiges FAQ-Widget. Unser KI Chatbot ist auf Ihr Unternehmen trainiert: Ihre Leistungen, Ihre Preise, Ihre Abläufe. Er führt echte Gespräche, qualifiziert Leads und bucht Termine direkt in Ihren Kalender — ohne dass Sie einen Finger rühren.</p>
            <a href="/website-relaunch" class="btn-secondary reveal" data-delay="0.3">Auch interessant: Website Relaunch →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="section-padding" id="leistungen">
      <div class="container">
        <div class="section-label reveal">Was Sie bekommen</div>
        <h2 class="reveal" data-delay="0.1">Alles, was ein guter Mitarbeiter kann — ohne Urlaub und ohne Krankheitstag.</h2>
        <div class="features-grid">
          <div class="feature-card card reveal" data-delay="0.1">
            <div class="feature-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="var(--color-primary)" stroke-width="1.5"/><path d="M12 6v6l4 2" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <h3>24 / 7 Verfügbarkeit</h3>
            <p>Der Chatbot ist immer da — morgens um 3, sonntags, an Feiertagen. Keine Anfrage geht verloren.</p>
          </div>
          <div class="feature-card card reveal" data-delay="0.15">
            <div class="feature-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M3 5h18M3 12h18M3 19h18" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <h3>Mehrsprachig</h3>
            <p>Deutsch und Englisch als Standard — weitere Sprachen auf Wunsch. Ideal für Kliniken und Praxen mit internationalem Patientenstamm.</p>
          </div>
          <div class="feature-card card reveal" data-delay="0.2">
            <div class="feature-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="18" rx="2" stroke="var(--color-primary)" stroke-width="1.5"/><path d="M16 2v4M8 2v4M3 10h18" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <h3>Terminbuchung direkt im Chat</h3>
            <p>Integration mit Google Calendar, Calendly oder Ihrem Praxisverwaltungssystem — der Termin landet automatisch im Kalender.</p>
          </div>
          <div class="feature-card card reveal" data-delay="0.25">
            <div class="feature-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3>Lead-Qualifizierung</h3>
            <p>Der Chatbot fragt die richtigen Informationen ab — Budget, Zeitraum, Art der Anfrage — bevor er Sie benachrichtigt. Sie erhalten nur qualifizierte Anfragen.</p>
          </div>
          <div class="feature-card card reveal" data-delay="0.3">
            <div class="feature-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3>DSGVO-konform</h3>
            <p>Datenhaltung auf deutschen Servern. Kein amerikanischer Anbieter, der Ihre Kundendaten weiterverarbeitet. Auftragsverarbeitungsvertrag inklusive.</p>
          </div>
          <div class="feature-card card reveal" data-delay="0.35">
            <div class="feature-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><polyline points="16 18 22 12 16 6" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><polyline points="8 6 2 12 8 18" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3>1 Code-Snippet, fertig</h3>
            <p>Integration per Copy-Paste — funktioniert auf jeder Website, egal ob WordPress, Jimdo oder individuelle Lösung. Kein IT-Aufwand.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Prozess -->
    <section class="section-padding prozess-section">
      <div class="container">
        <div class="section-label reveal">So läuft es ab</div>
        <h2 class="reveal" data-delay="0.1">Von der Analyse bis zum live Chatbot in 3 Schritten.</h2>
        <div class="prozess-steps">
          <div class="prozess-step reveal" data-delay="0.1">
            <div class="step-number mono text-amber">01</div>
            <div class="step-content">
              <h3>Analyse & Konzept</h3>
              <p>Wir schauen uns Ihr Unternehmen, Ihre häufigsten Anfragen und Ihre Ziele an. Dann definieren wir gemeinsam, was der Chatbot können soll.</p>
            </div>
          </div>
          <div class="prozess-connector" aria-hidden="true"></div>
          <div class="prozess-step reveal" data-delay="0.2">
            <div class="step-number mono text-amber">02</div>
            <div class="step-content">
              <h3>Training & Einrichtung</h3>
              <p>Wir trainieren den Chatbot auf Ihre Inhalte, Leistungen und Sprache. Terminbuchung, CRM-Anbindung und individuelle Logik werden konfiguriert.</p>
            </div>
          </div>
          <div class="prozess-connector" aria-hidden="true"></div>
          <div class="prozess-step reveal" data-delay="0.3">
            <div class="step-number mono text-amber">03</div>
            <div class="step-content">
              <h3>Launch & Optimierung</h3>
              <p>Der Chatbot geht live. Wir beobachten die ersten Gespräche und optimieren kontinuierlich. Sie sehen alles im Dashboard.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Branchen-Hinweis -->
    <section class="section-padding">
      <div class="container">
        <div class="branchen-hint reveal">
          <div class="bh-text">
            <div class="section-label">Branchenspezifisch</div>
            <h2 data-delay="0.1">Nicht für alle — sondern genau für Sie.</h2>
            <p>Ein Chatbot für eine Arztpraxis funktioniert anders als einer für einen Elektriker. Wir kennen die Unterschiede — und bauen entsprechend.</p>
            <div class="bh-links">
              <a href="/branchen/handwerk" class="btn-secondary">Handwerk</a>
              <a href="/branchen/arztpraxis" class="btn-secondary">Arztpraxis</a>
              <a href="/branchen/fitness-wellness" class="btn-secondary">Fitness & Beauty</a>
            </div>
          </div>
          <div class="bh-stats">
            <div class="bh-stat">
              <div class="stat-num mono text-amber">73%</div>
              <div class="stat-label">der Nutzer erwarten innerhalb von Minuten eine Antwort</div>
            </div>
            <div class="bh-stat">
              <div class="stat-num mono text-amber">24/7</div>
              <div class="stat-label">Verfügbarkeit — auch wenn Ihr Büro geschlossen hat</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section-padding" id="faq">
      <div class="container">
        <div class="section-label reveal">Häufige Fragen</div>
        <h2 class="reveal" data-delay="0.1">Was Sie wissen wollen, bevor Sie anfragen.</h2>
        <div class="faq-list">
          <details class="faq-item card reveal" data-delay="0.1">
            <summary class="faq-question">Was kostet ein KI Chatbot?</summary>
            <div class="faq-answer">
              <p>Ab 99 € pro Monat im Abo — inklusive Hosting, Updates und Support. Alternativ ist eine Einmalzahlung möglich. Der genaue Preis hängt vom Umfang ab: Terminbuchung, CRM-Anbindung und mehrere Sprachen kosten etwas mehr. In einem kostenlosen Erstgespräch nennen wir Ihnen eine konkrete Zahl.</p>
            </div>
          </details>
          <details class="faq-item card reveal" data-delay="0.15">
            <summary class="faq-question">Wie lange dauert die Einrichtung?</summary>
            <div class="faq-answer">
              <p>In der Regel 2 bis 4 Wochen vom Erstgespräch bis zum Live-Gang. Bei einfacheren Anforderungen auch schneller. Was wir von Ihnen brauchen: ein paar Stunden Ihrer Zeit für das Briefing und die Freigabe.</p>
            </div>
          </details>
          <details class="faq-item card reveal" data-delay="0.2">
            <summary class="faq-question">Ist das DSGVO-konform?</summary>
            <div class="faq-answer">
              <p>Ja. Datenhaltung auf deutschen Servern, Auftragsverarbeitungsvertrag (AVV) inklusive, keine Weitergabe an Drittanbieter. Für Arztpraxen und andere sensible Branchen gibt es zusätzliche Absicherungen. Wir beraten Sie gerne dazu.</p>
            </div>
          </details>
          <details class="faq-item card reveal" data-delay="0.25">
            <summary class="faq-question">Kann der Chatbot Termine in meinen Kalender buchen?</summary>
            <div class="faq-answer">
              <p>Ja. Wir integrieren den Chatbot mit Google Calendar, Calendly, Doctolib (für Praxen) oder einem anderen System, das Sie bereits nutzen. Der Termin erscheint automatisch — keine manuelle Nacharbeit.</p>
            </div>
          </details>
          <details class="faq-item card reveal" data-delay="0.3">
            <summary class="faq-question">Was passiert, wenn der Chatbot eine Frage nicht beantworten kann?</summary>
            <div class="faq-answer">
              <p>Der Chatbot leitet die Anfrage sauber weiter — per E-Mail an Sie oder per Hinweis auf Ihre Telefonnummer. Kein abruptes "Das weiß ich nicht". Wir trainieren ihn so, dass er auch bei unbekannten Fragen professionell reagiert. Außerdem lernt er durch jede Konversation.</p>
            </div>
          </details>
        </div>

        <script type="application/ld+json" is:inline>
        {
          "@context": "https://schema.org",
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "Was kostet ein KI Chatbot?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Ab 99 Euro pro Monat im Abo inklusive Hosting, Updates und Support. Alternativ ist eine Einmalzahlung möglich."
              }
            },
            {
              "@type": "Question",
              "name": "Wie lange dauert die Einrichtung?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "In der Regel 2 bis 4 Wochen vom Erstgespräch bis zum Live-Gang."
              }
            },
            {
              "@type": "Question",
              "name": "Ist das DSGVO-konform?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Ja. Datenhaltung auf deutschen Servern, Auftragsverarbeitungsvertrag inklusive, keine Weitergabe an Drittanbieter."
              }
            },
            {
              "@type": "Question",
              "name": "Kann der Chatbot Termine in meinen Kalender buchen?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Ja. Integration mit Google Calendar, Calendly, Doctolib oder einem anderen System das Sie bereits nutzen."
              }
            },
            {
              "@type": "Question",
              "name": "Was passiert wenn der Chatbot eine Frage nicht beantworten kann?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Der Chatbot leitet die Anfrage sauber weiter per E-Mail oder mit Hinweis auf die Telefonnummer."
              }
            }
          ]
        }
        </script>
      </div>
    </section>

    <!-- CTA -->
    <section class="section-padding cta-section" id="kontakt">
      <div class="container">
        <div class="cta-block reveal">
          <div class="section-label">Nächster Schritt</div>
          <h2>Sehen Sie den Chatbot live in Aktion.</h2>
          <p>Kostenlose Demo — 30 Minuten, unverbindlich, ohne Fachchinesisch. Wir zeigen Ihnen, wie ein auf Ihr Unternehmen trainierter Chatbot aussieht.</p>
          <div class="cta-actions">
            <a href="mailto:hallo@botmanufactory.de" class="btn-primary">Demo anfragen</a>
            <a href="/ki-telefonassistent" class="btn-secondary">Auch interessant: KI Telefonassistent →</a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* Hero */
  .leistung-hero {
    position: relative;
    padding-top: 160px;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-glow-1 {
    position: absolute;
    top: -100px;
    right: -100px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255,184,0,0.1) 0%, transparent 70%);
    animation: mesh-drift-1 12s ease-in-out infinite;
  }

  .hero-glow-2 {
    position: absolute;
    bottom: -100px;
    left: -100px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(0,212,255,0.06) 0%, transparent 70%);
    animation: mesh-drift-2 16s ease-in-out infinite;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 24px;
    font-family: var(--font-heading);
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    animation: pulse-glow 2s ease-in-out infinite;
    display: inline-block;
  }

  .hero-sub {
    font-size: clamp(18px, 2vw, 22px);
    color: var(--color-text-secondary);
    max-width: 640px;
    margin: 24px 0 40px;
    line-height: 1.6;
  }

  .hero-ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }

  .hero-trust {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  /* Section label */
  .section-label {
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 16px;
  }

  /* Problem */
  .problem-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .problem-card {
    padding: 32px;
  }

  .problem-icon {
    margin-bottom: 20px;
  }

  .problem-card h3 {
    font-size: 20px;
    margin-bottom: 12px;
  }

  .problem-card p {
    font-size: 16px;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  /* Solution */
  .solution-section {
    background: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .solution-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .solution-text h2 {
    margin-bottom: 24px;
  }

  .solution-text p {
    color: var(--color-text-secondary);
    margin-bottom: 32px;
  }

  /* Chat mockup */
  .chat-mockup {
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border-strong);
    border-radius: 16px;
    overflow: hidden;
    max-width: 420px;
  }

  .chat-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 20px 24px;
    background: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-border);
  }

