---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="KI Automatisierung für KMU | Prozesse die sich selbst erledigen | botmanufactory"
  description="Angebote, Rechnungen, Rapporte, Follow-ups — KI übernimmt Ihre Routineaufgaben. Für Handwerker, Arztpraxen und Mittelstand in Deutschland. Jetzt beraten lassen."
  canonical="https://botmanufactory.de/ki-automatisierung"
>
  <Nav />
  <main>

    <!-- Hero -->
    <section class="leistung-hero section-padding">
      <div class="hero-bg" aria-hidden="true">
        <div class="hero-glow-1"></div>
        <div class="hero-glow-2"></div>
      </div>
      <div class="container">
        <div class="hero-badge reveal">
          <span class="badge-dot" aria-hidden="true"></span>
          KI Automatisierung
        </div>
        <h1 class="reveal" data-delay="0.1">
          KI Automatisierung —<br />
          <span class="text-amber">damit Ihr Team Zeit für das Wesentliche hat.</span>
        </h1>
        <p class="hero-sub reveal" data-delay="0.2">
          Angebote tippen, Rapporte schreiben, E-Mails nachfassen, Daten übertragen — Stunden täglich für Aufgaben, die KI in Sekunden erledigt. Wir bauen die Automatisierungen, Sie ernten die Zeit.
        </p>
        <div class="hero-ctas reveal" data-delay="0.3">
          <a href="#kontakt" class="btn-primary">Kostenlose Prozessanalyse</a>
          <a href="#beispiele" class="btn-secondary">Beispiele ansehen</a>
        </div>
        <div class="hero-trust reveal" data-delay="0.4">
          <span class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/><polyline points="22 4 12 14.01 9 11.01" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Kein Softwarewechsel nötig
          </span>
          <span class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/><polyline points="22 4 12 14.01 9 11.01" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            DSGVO-konform
          </span>
          <span class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/><polyline points="22 4 12 14.01 9 11.01" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Messbare Zeitersparnis
          </span>
        </div>
      </div>
    </section>

    <!-- Problem -->
    <section class="section-padding">
      <div class="container">
        <div class="section-label reveal">Das Problem</div>
        <h2 class="reveal" data-delay="0.1">
          Ihr Team verbringt Stunden mit Aufgaben,<br />
          <span class="text-amber">die kein Mensch tun müsste.</span>
        </h2>
        <div class="problem-grid">
          <div class="problem-card card reveal" data-delay="0.1">
            <div class="problem-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" stroke="var(--color-error)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><polyline points="14 2 14 8 20 8" stroke="var(--color-error)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><line x1="16" y1="13" x2="8" y2="13" stroke="var(--color-error)" stroke-width="1.5" stroke-linecap="round"/><line x1="16" y1="17" x2="8" y2="17" stroke="var(--color-error)" stroke-width="1.5" stroke-linecap="round"/><polyline points="10 9 9 9 8 9" stroke="var(--color-error)" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <h3>Angebote manuell tippen</h3>
            <p>Ein Handwerker schreibt im Schnitt 3 bis 5 Angebote pro Woche — je 30 bis 60 Minuten. Das sind bis zu 5 Stunden pro Woche für reine Tipparbeit.</p>
          </div>
          <div class="problem-card card reveal" data-delay="0.2">
            <div class="problem-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" stroke="var(--color-error)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" stroke="var(--color-error)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3>Rapporte per Hand erfassen</h3>
            <p>Stundennachweise, Materialauflistungen, Tagesberichte — oft abends, wenn der Kopf schon müde ist. Fehlerquellen garantiert.</p>
          </div>
          <div class="problem-card card reveal" data-delay="0.3">
            <div class="problem-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="2" y="2" width="20" height="8" rx="2" stroke="var(--color-error)" stroke-width="1.5"/><rect x="2" y="14" width="20" height="8" rx="2" stroke="var(--color-error)" stroke-width="1.5"/><line x1="6" y1="6" x2="6.01" y2="6" stroke="var(--color-error)" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="18" x2="6.01" y2="18" stroke="var(--color-error)" stroke-width="2" stroke-linecap="round"/></svg>
            </div>
            <h3>Daten in mehrere Systeme</h3>
            <p>CRM, Rechnungssoftware, Kalender, E-Mail — dieselbe Information mehrfach eintragen, weil die Systeme nicht miteinander reden. Das kostet Zeit und produziert Fehler.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Beispiele -->
    <section class="section-padding beispiele-section" id="beispiele">
      <div class="container">
        <div class="section-label reveal">Konkrete Automatisierungen</div>
        <h2 class="reveal" data-delay="0.1">Was wir für Sie automatisieren können.</h2>
        <div class="beispiele-grid">
          <div class="beispiel-card card reveal" data-delay="0.1">
            <div class="bsp-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><polyline points="14 2 14 8 20 8" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3>Automatische Angebotserstellung</h3>
            <p>Leistung, Material, Menge eingeben — Angebot erscheint fertig formatiert, mit Ihrem Logo und Preisen, versandfertig als PDF. Unter 2 Minuten statt 45.</p>
            <div class="bsp-saving">
              <span class="mono text-amber">~5 Std./Woche</span> gespart
            </div>
          </div>
          <div class="beispiel-card card reveal" data-delay="0.15">
            <div class="bsp-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M19 10v2a7 7 0 0 1-14 0v-2M12 19v4M8 23h8" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3>Rapporterfassung per KI und Sprache</h3>
            <p>Sprechen Sie nach der Arbeit kurz in Ihr Smartphone — KI transkribiert, strukturiert und trägt den Rapport ein. Fertig in 2 Minuten.</p>
            <div class="bsp-saving">
              <span class="mono text-amber">~4 Std./Woche</span> gespart
            </div>
          </div>
          <div class="beispiel-card card reveal" data-delay="0.2">
            <div class="bsp-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><polyline points="22,6 12,13 2,6" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3>E-Mail-Workflows</h3>
            <p>Automatische Follow-up-E-Mails nach Angeboten, Terminbestätigungen, Erinnerungen — zeitgesteuert, personalisiert, ohne manuellen Aufwand.</p>
            <div class="bsp-saving">
              <span class="mono text-amber">~3 Std./Woche</span> gespart
            </div>
          </div>
          <div class="beispiel-card card reveal" data-delay="0.25">
            <div class="bsp-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="1" y="4" width="22" height="16" rx="2" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><line x1="1" y1="10" x2="23" y2="10" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <h3>Rechnungsverarbeitung</h3>
            <p>Eingehende Rechnungen per Scan oder E-Mail — KI liest aus, ordnet zu und überträgt in die Buchhaltung. Ohne Tippfehler, ohne Vergessen.</p>
            <div class="bsp-saving">
              <span class="mono text-amber">~2 Std./Woche</span> gespart
            </div>
          </div>
          <div class="beispiel-card card reveal" data-delay="0.3">
            <div class="bsp-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="var(--color-primary)" stroke-width="1.5"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <h3>CRM-Pflege automatisch</h3>
            <p>Neuer Kunde, neues Angebot, neue Kommunikation — KI pflegt das CRM automatisch. Sie sehen immer den aktuellen Stand, ohne etwas eintippen zu müssen.</p>
            <div class="bsp-saving">
              <span class="mono text-amber">~3 Std./Woche</span> gespart
            </div>
          </div>
          <div class="beispiel-card card reveal" data-delay="0.35">
            <div class="bsp-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="18" rx="2" stroke="var(--color-primary)" stroke-width="1.5"/><path d="M16 2v4M8 2v4M3 10h18" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <h3>Terminbestätigung automatisch</h3>
            <p>Jeder gebuchte Termin löst automatisch Bestätigungen, Erinnerungen und Nachfass-E-Mails aus — zum richtigen Zeitpunkt, ohne Zutun.</p>
            <div class="bsp-saving">
              <span class="mono text-amber">~2 Std./Woche</span> gespart
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Prozess -->
    <section class="section-padding prozess-section">
      <div class="container">
        <div class="section-label reveal">Unsere Vorgehensweise</div>
        <h2 class="reveal" data-delay="0.1">Analyse, Aufbau, Übergabe — in 4 Schritten.</h2>
        <div class="prozess-steps">
          <div class="prozess-step reveal" data-delay="0.1">
            <div class="step-number mono text-amber">01</div>
            <div class="step-content">
              <h3>Prozessanalyse</h3>
              <p>Wir schauen uns an, welche Aufgaben in Ihrem Unternehmen die meiste Zeit kosten und am stärksten automatisierbar sind. Das Ergebnis: eine klare Prioritätenliste.</p>
            </div>
          </div>
          <div class="prozess-step reveal" data-delay="0.2">
            <div class="step-number mono text-amber">02</div>
            <div class="step-content">
              <h3>Aufbau der Automatisierungen</h3>
              <p>Wir bauen die Workflows — ohne dass Sie Ihre bestehende Software wechseln müssen. Wir verbinden, was schon da ist, und füllen die Lücken.</p>
            </div>
          </div>
          <div class="prozess-step reveal" data-delay="0.3">
            <div class="step-number mono text-amber">03</div>
            <div class="step-content">
              <h3>Test & Freigabe</h3>
              <p>Gemeinsam testen wir die Automatisierungen mit echten Szenarien aus Ihrem Alltag. Erst wenn alles reibungslos läuft, schalten wir live.</p>
            </div>
          </div>
          <div class="prozess-step reveal" data-delay="0.4">
            <div class="step-number mono text-amber">04</div>
            <div class="step-content">
              <h3>Schulung & laufende Optimierung</h3>
              <p>Ihr Team lernt, wie die neuen Prozesse funktionieren. Wir bleiben als Ansprechpartner — und optimieren kontinuierlich, wenn sich Ihr Unternehmen verändert.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Cross-links -->
    <section class="section-padding">
      <div class="container">
        <div class="crosslink-row reveal">
          <div class="crosslink-card card">
            <div class="section-label">Mehr Effizienz</div>
            <h3>KI Dashboard</h3>
            <p>Alle automatisierten Prozesse, Chatbot-Statistiken und KI-Tools an einem Ort. Unser Eigenprodukt für Geschäftsführer.</p>
            <a href="/ki-dashboard" class="btn-secondary">Zum KI Dashboard →</a>
          </div>
          <div class="crosslink-card card">
            <div class="section-label">Für Handwerksbetriebe</div>
            <h3>Digitalisierung im Handwerk</h3>
            <p>Rapporte, Angebote, Terminbuchung — konkrete Automatisierungen für Elektriker, Gärtner und Sanitärbetriebe.</p>
            <a href="/branchen/handwerk" class="btn-secondary">Handwerk ansehen →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section-padding" id="faq">
      <div class="container">
        <div class="section-label reveal">Häufige Fragen</div>
        <h2 class="reveal" data-delay="0.1">Was Sie wissen wollen, bevor Sie anfragen.</h2>
        <div class="faq-list">
          <details class="faq-item card reveal" data-delay="0.1">
            <summary class="faq-question">Was kann automatisiert werden?</summary>
            <div class="faq-answer">
              <p>Grundsätzlich alles, was sich wiederholt und regelbasiert abläuft: Angebotserstellung, Rechnungsverarbeitung, E-Mail-Workflows, Datentransfer zwischen Systemen, Rapporterfassung, Terminmanagement. Im kostenlosen Erstgespräch analysieren wir, was bei Ihnen den größten Hebel hat.</p>
            </div>
          </details>
          <details class="faq-item card reveal" data-delay="0.15">
            <summary class="faq-question">Was kostet das?</summary>
            <div class="faq-answer">
              <p>Das hängt vom Umfang der Automatisierungen ab. Einfache Workflows sind günstiger, komplexe Integrationen kosten mehr. Wir nennen Ihnen im Erstgespräch eine konkrete Zahl — und zeigen Ihnen gleichzeitig, wie schnell sich die Investition amortisiert. In den meisten Fällen innerhalb weniger Monate.</p>
            </div>
          </details>
          <details class="faq-item card reveal" data-delay="0.2">
            <summary class="faq-question">Muss ich meine Software wechseln?</summary>
            <div class="faq-answer">
              <p>Nein. Wir arbeiten mit dem, was Sie schon haben — und verbinden es intelligenter. Ob DATEV, Lexoffice, Google Workspace, Outlook oder branchenspezifische Software: Wir analysieren, was möglich ist, und bauen die Verbindungen, die fehlen.</p>
            </div>
          </details>
          <details class="faq-item card reveal" data-delay="0.25">
            <summary class="faq-question">Wie lange dauert die Einrichtung?</summary>
            <div class="faq-answer">
              <p>Einfache Automatisierungen sind in 1 bis 2 Wochen live. Komplexere Setups mit mehreren Systemen und individuellen Logiken dauern 4 bis 8 Wochen. Wir nennen Ihnen nach dem Erstgespräch einen realistischen Zeitplan.</p>
            </div>
          </details>
          <details class="faq-item card reveal" data-delay="0.3">
            <summary class="faq-question">Was wenn etwas schief läuft?</summary>
            <div class="faq-answer">
              <p>Wir bauen Monitoring und Fallback-Mechanismen ein — wenn eine Automatisierung fehlschlägt, werden Sie sofort benachrichtigt und der Prozess läuft manuell weiter. Kein Datenverlust, kein Stillstand. Und wir sind als Ansprechpartner immer erreichbar.</p>
            </div>
          </details>
        </div>

        <script type="application/ld+json" is:inline>
        {
          "@context": "https://schema.org",
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "Was kann automatisiert werden?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Alles was sich wiederholt und regelbasiert abläuft: Angebotserstellung, Rechnungsverarbeitung, E-Mail-Workflows, Datentransfer, Rapporterfassung, Terminmanagement."
              }
            },
            {
              "@type": "Question",
              "name": "Was kostet das?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Das hängt vom Umfang ab. Einfache Workflows sind günstiger, komplexe Integrationen kosten mehr. Im Erstgespräch nennen wir eine konkrete Zahl."
              }
            },
            {
              "@type": "Question",
              "name": "Muss ich meine Software wechseln?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Nein. Wir arbeiten mit dem was Sie schon haben und verbinden es intelligenter."
              }
            },
            {
              "@type": "Question",
              "name": "Wie lange dauert die Einrichtung?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Einfache Automatisierungen in 1 bis 2 Wochen. Komplexere Setups dauern 4 bis 8 Wochen."
              }
            },
            {
              "@type": "Question",
              "name": "Was wenn etwas schief läuft?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Wir bauen Monitoring und Fallback-Mechanismen ein. Bei Fehlern werden Sie sofort benachrichtigt und der Prozess läuft manuell weiter."
              }
            }
          ]
        }
        </script>
      </div>
    </section>

    <!-- CTA -->
    <section class="section-padding cta-section" id="kontakt">
      <div class="container">
        <div class="cta-block reveal">
          <div class="section-label">Nächster Schritt</div>
          <h2>Kostenlose Prozessanalyse — wir zeigen, was möglich ist.</h2>
          <p>30 Minuten, unverbindlich. Wir schauen uns Ihre Abläufe an und sagen Ihnen konkret, wo KI die meiste Zeit spart — mit Zahlen, nicht mit Versprechen.</p>
          <div class="cta-actions">
            <a href="mailto:hallo@botmanufactory.de" class="btn-primary">Jetzt anfragen</a>
            <a href="/ki-chatbot" class="btn-secondary">Auch interessant: KI Chatbot →</a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .leistung-hero {
    position: relative;
    padding-top: 160px;
    overflow: hidden;
  }

  .hero-bg { position: absolute; inset: 0; pointer-events: none; }

  .hero-glow-1 {
    position: absolute;
    top: -100px;
    right: -100px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255,184,0,0.1) 0%, transparent 70%);
    animation: mesh-drift-1 12s ease-in-out infinite;
  }

  .hero-glow-2 {
    position: absolute;
    bottom: -100px;
    left: -100px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(0,212,255,0.06) 0%, transparent 70%);
    animation: mesh-drift-2 16s ease-in-out infinite;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 24px;
    font-family: var(--font-heading);
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    animation: pulse-glow 2s ease-in-out infinite;
    display: inline-block;
  }

  .hero-sub {
    font-size: clamp(18px, 2vw, 22px);
    color: var(--color-text-secondary);
    max-width: 640px;
    margin: 24px 0 40px;
    line-height: 1.6;
  }

  .hero-ctas { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 40px; }
  .hero-trust { display: flex; gap: 24px; flex-wrap: wrap; }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  .section-label {
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 16px;
  }

  .problem-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .problem-card { padding: 32px; }
  .problem-icon { margin-bottom: 20px; }
  .problem-card h3 { font-size: 20px; margin-bottom: 12px; }
  .problem-card p { font-size: 16px; color: var(--color-text-secondary); line-height: 1.7; margin: 0; }

  .beispiele-section {
    background: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .beispiele-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .beispiel-card { padding: 32px; }

  .bsp-icon {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    background: rgba(255,184,0,0.08);
