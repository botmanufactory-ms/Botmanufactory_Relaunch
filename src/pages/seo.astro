---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="SEO Agentur München — Seite 1 bei Google | botmanufactory"
  description="SEO für Handwerker, Arztpraxen und Mittelstand in München. Technisches SEO, lokales Google-Ranking und Content-Strategie aus einer Hand. Jetzt analysieren lassen."
  canonical="https://botmanufactory.de/seo"
>
  <Nav />
  <main>

    <!-- Hero -->
    <section class="leistung-hero section-padding">
      <div class="hero-bg" aria-hidden="true">
        <div class="hero-glow-1"></div>
        <div class="hero-glow-2"></div>
      </div>
      <div class="container">
        <div class="hero-badge reveal">
          <span class="badge-dot" aria-hidden="true"></span>
          SEO München
        </div>
        <h1 class="reveal" data-delay="0.1">
          SEO München —<br />
          <span class="text-amber">damit Sie bei Google gefunden werden.</span>
        </h1>
        <p class="hero-sub reveal" data-delay="0.2">
          Wer Ihre Leistungen googelt, findet aktuell Ihre Mitbewerber — nicht Sie. Das ändern wir. Technisches SEO, lokales Ranking und KI-gestützte Content-Strategie aus einer Hand. Für Handwerker, Arztpraxen und Mittelstand in München.
        </p>
        <div class="hero-ctas reveal" data-delay="0.3">
          <a href="#kontakt" class="btn-primary">Kostenlose SEO-Analyse</a>
          <a href="#leistungen" class="btn-secondary">Unsere SEO-Leistungen</a>
        </div>
        <div class="hero-trust reveal" data-delay="0.4">
          <span class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" stroke="var(--color-primary)" stroke-width="1.5"/><circle cx="12" cy="10" r="3" stroke="var(--color-primary)" stroke-width="1.5"/></svg>
            München & Bayern
          </span>
          <span class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/><polyline points="22 4 12 14.01 9 11.01" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            KI-gestützte Content-Erstellung
          </span>
          <span class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/><polyline points="22 4 12 14.01 9 11.01" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Messbare Ergebnisse
          </span>
        </div>
      </div>
    </section>

    <!-- Problem -->
    <section class="section-padding">
      <div class="container">
        <div class="section-label reveal">Das Problem</div>
        <h2 class="reveal" data-delay="0.1">
          Seite 3 bei Google ist wie<br />
          <span class="text-amber">unsichtbar sein.</span>
        </h2>
        <div class="problem-grid">
          <div class="problem-card card reveal" data-delay="0.1">
            <div class="problem-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="8" stroke="var(--color-error)" stroke-width="1.5"/><path d="m21 21-4.35-4.35" stroke="var(--color-error)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><line x1="11" y1="8" x2="11" y2="14" stroke="var(--color-error)" stroke-width="1.5" stroke-linecap="round"/><line x1="8" y1="11" x2="14" y2="11" stroke="var(--color-error)" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <h3>Ihre Mitbewerber werden gefunden</h3>
            <p>In München gibt es viele Handwerker, Praxen und Dienstleister. Wer auf Seite 1 steht, bekommt die Anfragen — der Rest wartet.</p>
          </div>
          <div class="problem-card card reveal" data-delay="0.2">
            <div class="problem-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" stroke="var(--color-error)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3>Google Ads kosten viel — und hören auf</h3>
            <p>Bezahlte Anzeigen funktionieren nur, solange Sie zahlen. Organisches SEO ist langfristiger und günstiger — aber braucht Zeit und Strategie.</p>
          </div>
          <div class="problem-card card reveal" data-delay="0.3">
            <div class="problem-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M3 3l18 18M10.5 10.677A2 2 0 0 0 10 12a2 2 0 1 0 3.56-1.286" stroke="var(--color-error)" stroke-width="1.5" stroke-linecap="round"/><path d="M7.362 7.561C5.68 8.74 4.279 10.42 3.46 12.5a10 10 0 0 0 14.907 4.16M9.13 4.225A10 10 0 0 1 21.22 13.5c-.145.536-.335 1.06-.567 1.566" stroke="var(--color-error)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3>Technische Fehler blockieren das Ranking</h3>
            <p>Fehlende Alt-Texte, langsame Ladezeiten, doppelte Inhalte — viele Websites haben technische Probleme, die Google abstrafen, ohne dass der Inhaber es weiß.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Leistungen -->
    <section class="section-padding seo-leistungen-section" id="leistungen">
      <div class="container">
        <div class="section-label reveal">Unsere SEO-Leistungen</div>
        <h2 class="reveal" data-delay="0.1">Was wir für Ihr Ranking tun.</h2>
        <div class="seo-grid">
          <div class="seo-card card reveal" data-delay="0.1">
            <div class="seo-num mono text-amber">01</div>
            <h3>Technisches SEO-Audit</h3>
            <p>Wir analysieren Ihre Website vollständig: Ladezeiten, Crawling-Fehler, Indexierung, Core Web Vitals, Mobile-Optimierung. Das Audit zeigt, was Google ausbremst — und wie wir es beheben.</p>
          </div>
          <div class="seo-card card reveal" data-delay="0.15">
            <div class="seo-num mono text-amber">02</div>
            <h3>OnPage-Optimierung</h3>
            <p>Titles, Descriptions, Überschriften, interne Verlinkung, Bilder-Optimierung — alles systematisch für jede wichtige Seite. Keine blinde Keyword-Stopfung, sondern sinnvolle Optimierung.</p>
          </div>
          <div class="seo-card card reveal" data-delay="0.2">
            <div class="seo-num mono text-amber">03</div>
            <h3>Lokales SEO und Google Business</h3>
            <p>Für München und Umgebung: Google Business Profile-Optimierung, lokale Keywords, Brancheneinträge und Bewertungsmanagement. Damit Sie in der Google-Maps-Suche auftauchen.</p>
          </div>
          <div class="seo-card card reveal" data-delay="0.25">
            <div class="seo-num mono text-amber">04</div>
            <h3>Content-Strategie</h3>
            <p>Welche Inhalte sucht Ihre Zielgruppe? Wir entwickeln eine Content-Strategie, die auf echte Suchanfragen einzahlt — und Ihre Expertise sichtbar macht.</p>
          </div>
          <div class="seo-card card reveal" data-delay="0.3">
            <div class="seo-num mono text-amber">05</div>
            <h3>KI-gestützte Content-Erstellung</h3>
            <p>Wir nutzen KI, um Inhalte schneller und günstiger zu erstellen — ohne dass die Qualität leidet. Das bedeutet: mehr relevante Seiten in weniger Zeit, zu KMU-Preisen.</p>
            <div class="seo-highlight">Unser Vorteil: schneller und günstiger als klassische Agenturen</div>
          </div>
          <div class="seo-card card reveal" data-delay="0.35">
            <div class="seo-num mono text-amber">06</div>
            <h3>Backlink-Aufbau</h3>
            <p>Qualitativ hochwertige Links von relevanten deutschen Websites — nicht Massenlink-Kauf. Gezielter Aufbau von Autorität über echte Branchenverzeichnisse und Partnerschaften.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- KI-Vorteil -->
    <section class="section-padding ki-vorteil-section">
      <div class="container">
        <div class="ki-vorteil-block reveal">
          <div class="kv-badge">Besonderheit bei Botmanufactory</div>
          <h2>KI im SEO-Prozess — schneller, günstiger, besser messbar.</h2>
          <p>Klassische SEO-Agenturen erstellen Content manuell — das ist langsam und teuer. Wir setzen KI ein, um Keyword-Analysen, Content-Briefings und erste Textentwürfe schneller zu produzieren. Das Ergebnis: mehr relevante Inhalte für Ihr Budget, in weniger Zeit.</p>
          <p>Dabei schreiben wir nie "KI-Texte" ohne menschliche Kontrolle. Jeder Inhalt wird geprüft, angepasst und auf Ihre Sprache und Branche abgestimmt.</p>
          <div class="kv-stats">
            <div class="kv-stat">
              <div class="kvs-num mono text-amber">3–6</div>
              <div class="kvs-label">Monate bis erste Rankings sichtbar werden</div>
            </div>
            <div class="kv-stat">
              <div class="kvs-num mono text-amber">12+</div>
              <div class="kvs-label">Monate für stabile Top-10-Positionen bei kompetitiven Keywords</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Prozess -->
    <section class="section-padding prozess-section">
      <div class="container">
        <div class="section-label reveal">Unser Vorgehen</div>
        <h2 class="reveal" data-delay="0.1">SEO ist kein Einmalauftrag — sondern ein laufender Prozess.</h2>
        <div class="prozess-steps">
          <div class="prozess-step reveal" data-delay="0.1">
            <div class="step-number mono text-amber">01</div>
            <div class="step-content">
              <h3>Analyse und Keyword-Recherche</h3>
              <p>Wir analysieren Ihre Website, Ihre Mitbewerber und die Suchbegriffe, die Ihre Zielgruppe wirklich nutzt. Ergebnis: eine priorisierte Keyword-Strategie.</p>
            </div>
          </div>
          <div class="prozess-step reveal" data-delay="0.2">
            <div class="step-number mono text-amber">02</div>
            <div class="step-content">
              <h3>Technische Basis schaffen</h3>
              <p>Alle technischen Fehler beheben, die Google ausbremsen. Ladezeiten verbessern, Crawling-Probleme lösen, Mobile-Optimierung sicherstellen.</p>
            </div>
          </div>
          <div class="prozess-step reveal" data-delay="0.3">
            <div class="step-number mono text-amber">03</div>
            <div class="step-content">
              <h3>Content-Aufbau</h3>
              <p>Seiten optimieren, neue Inhalte erstellen, lokale Präsenz aufbauen. Monat für Monat mehr relevante Inhalte, die auf echte Suchen einzahlen.</p>
            </div>
          </div>
          <div class="prozess-step reveal" data-delay="0.4">
            <div class="step-number mono text-amber">04</div>
            <div class="step-content">
              <h3>Messen und Optimieren</h3>
              <p>Transparentes Reporting: Was rankt, was nicht, was als nächstes. Monatlich klare Zahlen statt Marketing-Sprech.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section-padding" id="faq">
      <div class="container">
        <div class="section-label reveal">Häufige Fragen</div>
        <h2 class="reveal" data-delay="0.1">Was Sie wissen wollen, bevor Sie anfragen.</h2>
        <div class="faq-list">
          <details class="faq-item card reveal" data-delay="0.1">
            <summary class="faq-question">Wie lange bis zum Ranking?</summary>
            <div class="faq-answer">
              <p>Ehrliche Antwort: 3 bis 6 Monate bis erste Verbesserungen sichtbar werden, 6 bis 12 Monate für stabile Positionen bei kompetitiven Keywords. Wer kurzfristige Wunder verspricht, lügt. SEO ist ein Investmentprozess, kein Schalter.</p>
            </div>
          </details>
          <details class="faq-item card reveal" data-delay="0.15">
            <summary class="faq-question">Was kostet SEO?</summary>
            <div class="faq-answer">
              <p>Unsere SEO-Pakete starten ab 500 € pro Monat für lokales SEO (München, Umgebung). Umfangreichere Projekte mit Content-Strategie und Backlink-Aufbau kosten mehr. Im Erstgespräch nennen wir Ihnen konkrete Zahlen auf Basis Ihrer Situation und Ihrer Ziele.</p>
            </div>
          </details>
          <details class="faq-item card reveal" data-delay="0.2">
            <summary class="faq-question">Garantieren Sie Rankings?</summary>
            <div class="faq-answer">
              <p>Nein — und jeder der das tut, lügt oder redet von unwichtigen Keywords. Google ändert seinen Algorithmus ständig. Wir garantieren professionelle Arbeit, transparente Prozesse und messbare Fortschritte — aber keine spezifischen Ranking-Positionen.</p>
            </div>
          </details>
          <details class="faq-item card reveal" data-delay="0.25">
            <summary class="faq-question">Was ist der Unterschied zu Google Ads?</summary>
            <div class="faq-answer">
              <p>Google Ads bringt sofort Traffic — solange Sie zahlen. Hören Sie auf, verschwinden Sie. SEO braucht Zeit, bringt dann aber dauerhaften, kostenlosen organischen Traffic. Beides hat seinen Platz: Ads für schnelle Ergebnisse, SEO als langfristige Grundlage.</p>
            </div>
          </details>
          <details class="faq-item card reveal" data-delay="0.3">
            <summary class="faq-question">Brauche ich dafür eine neue Website?</summary>
            <div class="faq-answer">
              <p>Nicht zwingend. Wir optimieren was da ist — oder empfehlen einen Relaunch, wenn die technische Grundlage zu schlecht ist. In unserem kostenlosen Audit sehen Sie sofort, ob Ihre aktuelle Website SEO-tauglich ist.</p>
            </div>
          </details>
        </div>

        <script type="application/ld+json" is:inline>
        {
          "@context": "https://schema.org",
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "Wie lange bis zum Ranking?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "3 bis 6 Monate bis erste Verbesserungen sichtbar werden, 6 bis 12 Monate für stabile Positionen bei kompetitiven Keywords."
              }
            },
            {
              "@type": "Question",
              "name": "Was kostet SEO?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Unsere SEO-Pakete starten ab 500 Euro pro Monat für lokales SEO in München und Umgebung."
              }
            },
            {
              "@type": "Question",
              "name": "Garantieren Sie Rankings?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Nein. Wir garantieren professionelle Arbeit und messbare Fortschritte, aber keine spezifischen Ranking-Positionen."
              }
            },
            {
              "@type": "Question",
              "name": "Was ist der Unterschied zu Google Ads?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Google Ads bringt sofort Traffic solange Sie zahlen. SEO braucht Zeit, bringt dann aber dauerhaften organischen Traffic."
              }
            },
            {
              "@type": "Question",
              "name": "Brauche ich dafür eine neue Website?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Nicht zwingend. Wir optimieren was da ist oder empfehlen einen Relaunch wenn die technische Grundlage zu schlecht ist."
              }
            }
          ]
        }
        </script>
      </div>
    </section>

    <!-- CTA -->
    <section class="section-padding cta-section" id="kontakt">
      <div class="container">
        <div class="cta-block reveal">
          <div class="section-label">Nächster Schritt</div>
          <h2>Kostenlose SEO-Analyse — sehen Sie wo Sie stehen.</h2>
          <p>Wir analysieren Ihre Website, schauen auf Ihre Mitbewerber in München und zeigen Ihnen, welche Suchbegriffe Sie liegen lassen. Kostenlos, unverbindlich, in 30 Minuten.</p>
          <div class="cta-actions">
            <a href="mailto:hallo@botmanufactory.de" class="btn-primary">Kostenlose Analyse anfragen</a>
            <a href="/webdesign-muenchen" class="btn-secondary">Auch interessant: Webdesign München →</a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .leistung-hero {
    position: relative;
    padding-top: 160px;
    overflow: hidden;
  }

  .hero-bg { position: absolute; inset: 0; pointer-events: none; }

  .hero-glow-1 {
    position: absolute;
    top: -100px;
    right: -100px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255,184,0,0.1) 0%, transparent 70%);
    animation: mesh-drift-1 12s ease-in-out infinite;
  }

  .hero-glow-2 {
    position: absolute;
    bottom: -100px;
    left: -100px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(0,212,255,0.06) 0%, transparent 70%);
    animation: mesh-drift-2 16s ease-in-out infinite;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 24px;
    font-family: var(--font-heading);
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    animation: pulse-glow 2s ease-in-out infinite;
    display: inline-block;
  }

  .hero-sub {
    font-size: clamp(18px, 2vw, 22px);
    color: var(--color-text-secondary);
    max-width: 640px;
    margin: 24px 0 40px;
    line-height: 1.6;
  }

  .hero-ctas { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 40px; }
  .hero-trust { display: flex; gap: 24px; flex-wrap: wrap; }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  .section-label {
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 16px;
  }

  .problem-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .problem-card { padding: 32px; }
  .problem-icon { margin-bottom: 20px; }
  .problem-card h3 { font-size: 20px; margin-bottom: 12px; }
  .problem-card p { font-size: 16px; color: var(--color-text-secondary); line-height: 1.7; margin: 0; }

  /* SEO Leistungen */
  .seo-leistungen-section {
    background: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .seo-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 48px;
  }

  .seo-card { padding: 36px; }

  .seo-num {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.1em;
    margin-bottom: 16px;
  }

  .seo-card h3 { font-size: 22px; margin-bottom: 12px; }

  .seo-card p {
    font-size: 16px;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .seo-highlight {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary);
    background: rgba(255,184,0,0.08);
    border: 1px solid rgba(255,184,0,0.15);
    border-radius: 6px;
    padding: 8px 12px;
  }

  /* KI Vorteil */
  .ki-vorteil-section {
    background: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .ki-vorteil-block {
    max-width: 800px;
  }

  .kv-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    background: rgba(255,184,0,0.1);
    border: 1px solid rgba(255,184,0,0.2);
    border-radius: 4px;
    padding: 4px 12px;
    margin-bottom: 20px;
    font-family: var(--font-heading);
  }

  .ki-vorteil-block h2 { margin-bottom: 20px; }

  .ki-vorteil-block p {
    color: var(--color-text-secondary);
    font-size: 17px;
    margin-bottom: 16px;
    line-height: 1.7;
  }

  .kv-stats {
    display: flex;
    gap: 64px;
    margin-top: 40px;
    padding-top: 40px;
    border-top: 1px solid var(--color-border);
  }

  .kvs-num {
    font-size: 52px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 8px;
  }

  .kvs-label {
    font-size: 14px;
    color: var(--color-text-secondary);
    max-width: 200px;
    line-height: 1.5;
  }

  /* Prozess */
  .prozess-section {
    background: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .prozess-steps {
    margin-top: 48px;
    display: flex;
    flex-direction: column;
  }

  .prozess-step {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 32px;
    padding: 40px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .prozess-step:last-child { border-bottom: none; }

  .step-number {
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
    padding-top: 4px;
  }

  .step-content h3 { font-size: 22px; margin-bottom: 12px; }
  .step-content p { color: var(--color-text-secondary); margin: 0; font-size: 16px; }

  .faq-list {
    margin-top: 48px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .faq-item { padding: 0; overflow: hidden; }

  .faq-question {
    padding: 24px 28px;
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    transition: color 0.2s;
  }

  .faq-question::-webkit-details-marker { display: none; }

  .faq-question::after {
    content: '+';
