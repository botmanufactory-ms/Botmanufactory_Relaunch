---
---

<section id="hero" aria-label="Hero">
  <!-- Animated mesh background -->
  <div class="mesh" aria-hidden="true">
    <div class="mesh-blob mesh-1"></div>
    <div class="mesh-blob mesh-2"></div>
    <div class="mesh-blob mesh-3"></div>
    <div class="mesh-grid"></div>
  </div>

  <div class="container hero-inner">
    <!-- Badge -->
    <div class="hero-badge reveal" data-delay="0">
      <span class="badge-dot" aria-hidden="true"></span>
      KI-Agentur &amp; Webdesign · Made in Bayern
    </div>

    <!-- Headline -->
    <h1 class="hero-h1" id="hero-title">
      <span class="h1-line reveal" data-delay="0.1">KI-Agentur &amp;</span>
      <span class="h1-line reveal" data-delay="0.2">Webdesign München</span>
      <span class="h1-line h1-accent reveal" data-delay="0.3">für den Mittelstand.</span>
    </h1>

    <!-- Subline -->
    <p class="hero-sub reveal" data-delay="0.4">
      Digitale Sichtbarkeit. Automatisierte Prozesse. Wir bauen beides —
      Schritt für Schritt, so wie es zu Ihrem Unternehmen passt.
    </p>

    <!-- CTAs -->
    <div class="hero-ctas reveal" data-delay="0.5">
      <div class="magnetic-wrap">
        <a href="#kontakt" class="btn-primary magnetic-btn" id="hero-cta">
          Kostenlose Analyse sichern
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
      <a href="#leistungen" class="btn-secondary">
        Unsere Leistungen
      </a>
    </div>

    <!-- Trust badges -->
    <div class="trust-row reveal" data-delay="0.6" aria-label="Vertrauensmerkmale">
      <div class="trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Made in Bayern
      </div>
      <div class="trust-sep" aria-hidden="true">·</div>
      <div class="trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        DSGVO-konform
      </div>
      <div class="trust-sep" aria-hidden="true">·</div>
      <div class="trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="9" cy="7" r="4" stroke="var(--color-primary)" stroke-width="1.5"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Persönlich vor Ort
      </div>
      <div class="trust-sep" aria-hidden="true">·</div>
      <div class="trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="10" stroke="var(--color-primary)" stroke-width="1.5"/>
          <path d="M12 6v6l4 2" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Kompetitive Preise
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator reveal" data-delay="1" aria-hidden="true">
    <span>Scrollen</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  #hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: 72px;
  }

  /* Mesh background */
  .mesh {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .mesh-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }

  .mesh-1 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255, 184, 0, 0.12) 0%, transparent 70%);
    top: -100px;
    right: -100px;
    animation: mesh-drift-1 18s ease-in-out infinite;
  }

  .mesh-2 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(0, 212, 255, 0.07) 0%, transparent 70%);
    bottom: 0;
    left: -80px;
    animation: mesh-drift-2 22s ease-in-out infinite;
  }

  .mesh-3 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(255, 184, 0, 0.06) 0%, transparent 70%);
    top: 40%;
    left: 40%;
    animation: mesh-drift-3 15s ease-in-out infinite;
  }

  /* Subtle grid overlay */
  .mesh-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--color-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-border) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.25;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
  }

  /* Hero content */
  .hero-inner {
    position: relative;
    z-index: 1;
    padding-top: 80px;
    padding-bottom: 80px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 184, 0, 0.08);
    border: 1px solid rgba(255, 184, 0, 0.2);
    border-radius: 4px;
    padding: 6px 14px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-family: var(--font-heading);
    color: var(--color-primary);
    margin-bottom: 32px;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background: var(--color-primary);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--color-primary);
    animation: pulse-glow 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  /* Headline */
  .hero-h1 {
    display: flex;
    flex-direction: column;
    max-width: 820px;
    margin-bottom: 28px;
  }

  .h1-line {
    display: block;
  }

  .h1-accent {
    color: var(--color-primary);
  }

  .hero-sub {
    font-size: clamp(17px, 1.5vw, 20px);
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin-bottom: 40px;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 56px;
  }

  /* Trust row */
  .trust-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--color-text-muted);
    font-size: 13px;
    font-weight: 500;
  }

  .trust-sep {
    color: var(--color-border-strong);
    font-size: 16px;
  }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: var(--color-text-muted);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--color-border-strong), transparent);
    animation: float 2s ease-in-out infinite;
  }

  /* Magnetic button */
  .magnetic-btn {
    animation: pulse-glow 3s ease-in-out infinite;
  }

  @media (max-width: 640px) {
    .trust-sep { display: none; }
    .trust-row { gap: 8px; }
    .hero-ctas { flex-direction: column; align-items: flex-start; }
    .scroll-indicator { display: none; }
  }
</style>

<script>
  // Magnetic CTA button
  const cta = document.getElementById('hero-cta')!;

  cta.addEventListener('mousemove', (e: MouseEvent) => {
    const rect = cta.getBoundingClientRect();
    const x = e.clientX - rect.left - rect.width / 2;
    const y = e.clientY - rect.top - rect.height / 2;
    cta.style.transform = `translate(${x * 0.25}px, ${y * 0.4}px) translateY(-1px)`;
  });

  cta.addEventListener('mouseleave', () => {
    cta.style.transform = '';
  });
</script>
