---
const regions = [
  { name: "München", desc: "Hauptmarkt", primary: true },
  { name: "Vaterstetten", desc: "Heimatstandort", primary: true },
  { name: "Baldham", desc: "Landkreis Ebersberg", primary: false },
  { name: "Poing", desc: "Landkreis Ebersberg", primary: false },
  { name: "Landshut", desc: "Persönlich vor Ort", primary: false },
  { name: "Augsburg", desc: "Persönlich vor Ort", primary: false },
  { name: "Ingolstadt", desc: "Persönlich vor Ort", primary: false },
];
---

<section class="section-padding region-section" aria-labelledby="region-heading">
  <div class="container">
    <div class="region-grid">
      <!-- Left: Text -->
      <div class="region-text">
        <div class="section-label reveal">Vor Ort in Bayern</div>
        <h2 id="region-heading" class="reveal" data-delay="0.1">
          Kein Ferndienstleister.<br />
          <span class="text-amber">Persönlich bei Ihnen.</span>
        </h2>
        <p class="region-sub reveal" data-delay="0.2">
          Wir kommen zu Ihnen. Ob Erstgespräch, Workshop oder Projektabnahme —
          persönlicher Kontakt ist uns wichtig. Im Landkreis München und darüber hinaus.
        </p>

        <div class="regions-list reveal" data-delay="0.3" role="list" aria-label="Einzugsgebiet">
          {regions.map(r => (
            <div class="region-item" role="listitem">
              <div class={`region-dot ${r.primary ? 'region-dot-primary' : ''}`} aria-hidden="true"></div>
              <div class="region-info">
                <span class="region-name">{r.name}</span>
                <span class="region-desc">{r.desc}</span>
              </div>
            </div>
          ))}
        </div>

        <div class="region-note reveal" data-delay="0.4">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" stroke="var(--color-primary)" stroke-width="1.5"/>
            <circle cx="12" cy="10" r="3" stroke="var(--color-primary)" stroke-width="1.5"/>
          </svg>
          Bundesweit auch remote verfügbar — mit dem gleichen Engagement.
        </div>
      </div>

      <!-- Right: SVG Map of Bavaria (simplified) -->
      <div class="region-map reveal" data-delay="0.2" aria-hidden="true">
        <div class="map-container">
          <!-- Simplified Bavaria outline SVG -->
          <svg viewBox="0 0 400 360" fill="none" class="bavaria-svg" role="img" aria-label="Bayern Karte mit markierten Standorten">
            <!-- Bayern outline (simplified) -->
            <path
              d="M 80 40 L 100 20 L 140 15 L 180 20 L 220 10 L 280 25 L 320 40 L 360 80 L 370 120 L 360 160 L 380 200 L 360 240 L 330 280 L 280 300 L 250 320 L 220 330 L 180 340 L 150 330 L 120 310 L 90 280 L 60 240 L 40 200 L 30 160 L 40 120 L 60 80 Z"
              stroke="var(--color-border-strong)"
              stroke-width="2"
              fill="rgba(15,17,23,0.6)"
              stroke-linejoin="round"
            />

            <!-- Internal lines for texture -->
            <path d="M 100 100 L 180 80 L 280 100 L 320 160 L 280 220 L 200 240 L 120 220 L 80 160 Z"
              stroke="var(--color-border)"
              stroke-width="1"
              fill="none"
              opacity="0.4"
            />

            <!-- River lines -->
            <path d="M 180 60 Q 200 120 220 180 Q 240 240 230 300"
              stroke="rgba(0,212,255,0.2)"
              stroke-width="1.5"
              fill="none"
              stroke-linecap="round"
            />

            <!-- City markers -->
            <!-- München (primary) -->
            <g transform="translate(190, 210)">
              <circle cx="0" cy="0" r="8" fill="var(--color-primary)" opacity="0.2"/>
              <circle cx="0" cy="0" r="4" fill="var(--color-primary)"/>
              <circle cx="0" cy="0" r="4" fill="transparent" stroke="var(--color-primary)" stroke-width="1">
                <animate attributeName="r" values="4;14;4" dur="2s" repeatCount="indefinite"/>
                <animate attributeName="opacity" values="0.6;0;0.6" dur="2s" repeatCount="indefinite"/>
              </circle>
              <text x="12" y="5" font-size="11" fill="var(--color-text-primary)" font-family="Inter,sans-serif" font-weight="600">München</text>
            </g>

            <!-- Vaterstetten (primary) -->
            <g transform="translate(220, 225)">
              <circle cx="0" cy="0" r="6" fill="var(--color-primary)" opacity="0.15"/>
              <circle cx="0" cy="0" r="3" fill="var(--color-primary)"/>
              <text x="10" y="4" font-size="9" fill="var(--color-text-secondary)" font-family="Inter,sans-serif">Vaterstetten</text>
            </g>

            <!-- Landshut -->
            <g transform="translate(275, 170)">
              <circle cx="0" cy="0" r="3" fill="var(--color-primary)" opacity="0.6"/>
              <text x="8" y="4" font-size="9" fill="var(--color-text-muted)" font-family="Inter,sans-serif">Landshut</text>
            </g>

            <!-- Augsburg -->
            <g transform="translate(130, 220)">
              <circle cx="0" cy="0" r="3" fill="var(--color-primary)" opacity="0.6"/>
              <text x="8" y="4" font-size="9" fill="var(--color-text-muted)" font-family="Inter,sans-serif">Augsburg</text>
            </g>

            <!-- Ingolstadt -->
            <g transform="translate(195, 130)">
              <circle cx="0" cy="0" r="3" fill="var(--color-primary)" opacity="0.6"/>
              <text x="8" y="4" font-size="9" fill="var(--color-text-muted)" font-family="Inter,sans-serif">Ingolstadt</text>
            </g>

            <!-- Poing -->
            <g transform="translate(240, 215)">
              <circle cx="0" cy="0" r="2" fill="var(--color-primary)" opacity="0.5"/>
            </g>

            <!-- Baldham -->
            <g transform="translate(232, 222)">
              <circle cx="0" cy="0" r="2" fill="var(--color-primary)" opacity="0.5"/>
            </g>
          </svg>

          <div class="map-label">Bayern &amp; Bundesweit</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .region-section {
    background: linear-gradient(180deg, transparent, rgba(15,17,23,0.5), transparent);
  }

  .section-label {
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 24px;
    display: block;
  }

  .region-grid {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 80px;
    align-items: center;
  }

  .region-sub {
    color: var(--color-text-secondary);
    max-width: 480px;
    margin-bottom: 40px;
  }

  h2 { margin-bottom: 16px; }

  .regions-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 32px;
  }

  .region-item {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .region-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-border-strong);
    flex-shrink: 0;
    transition: background 0.2s;
  }

  .region-dot-primary {
    background: var(--color-primary);
    box-shadow: 0 0 8px var(--color-primary-glow);
  }

  .region-info {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .region-name {
    font-weight: 600;
    font-size: 15px;
    color: var(--color-text-primary);
  }

  .region-desc {
    font-size: 13px;
    color: var(--color-text-muted);
  }

  .region-note {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 16px 20px;
    background: rgba(255, 184, 0, 0.05);
    border: 1px solid rgba(255, 184, 0, 0.15);
    border-radius: 8px;
    font-size: 14px;
    color: var(--color-text-secondary);
  }

  /* Map */
  .map-container {
    position: relative;
  }

  .bavaria-svg {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 0 40px rgba(255, 184, 0, 0.05));
  }

  .map-label {
    text-align: center;
    font-size: 12px;
    color: var(--color-text-muted);
    margin-top: 12px;
    font-family: var(--font-heading);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .region-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .region-map {
      max-width: 360px;
      margin: 0 auto;
    }
  }
</style>
