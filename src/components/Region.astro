---
const regions = [
  { name: "München", desc: "Hauptmarkt", primary: true },
  { name: "Vaterstetten", desc: "Heimatstandort", primary: true },
  { name: "Baldham", desc: "Landkreis Ebersberg", primary: false },
  { name: "Poing", desc: "Landkreis Ebersberg", primary: false },
  { name: "Landshut", desc: "Landkreis Landshut", primary: false },
  { name: "Augsburg", desc: "Schwaben", primary: false },
  { name: "Ingolstadt", desc: "Oberbayern", primary: false },
];
---

<section class="section-padding region-section" aria-labelledby="region-heading">
  <div class="container">
    <div class="region-grid">
      <!-- Left: Text -->
      <div class="region-text">
        <div class="section-label reveal">Deutschlandweit</div>
        <h2 id="region-heading" class="reveal" data-delay="0.1">
          Bundesweit remote.<br />
          <span class="text-amber">In Bayern auch persönlich.</span>
        </h2>
        <p class="region-sub reveal" data-delay="0.2">
          Projekte entstehen digital — egal ob Hamburg, Berlin oder München.
          Wer in der Nähe ist: wir können uns auch persönlich kennenlernen
          und die Zusammenarbeit in Ruhe besprechen.
        </p>

        <div class="regions-list reveal" data-delay="0.3" role="list" aria-label="Persönliche Treffen möglich in">
          <div class="regions-list-label">Persönliche Treffen möglich in</div>
          {regions.map(r => (
            <div class="region-item" role="listitem">
              <div class={`region-dot ${r.primary ? 'region-dot-primary' : ''}`} aria-hidden="true"></div>
              <div class="region-info">
                <span class="region-name">{r.name}</span>
                <span class="region-desc">{r.desc}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Visual -->
      <div class="region-visual reveal" data-delay="0.2" aria-hidden="true">
        <div class="visual-card">
          <div class="visual-header">
            <div class="visual-dot-primary">
              <span class="pulse-ring"></span>
            </div>
            <div class="visual-header-text">
              <div class="visual-title">Vaterstetten · Bayern</div>
              <div class="visual-sub">Heimatstandort</div>
            </div>
          </div>

          <div class="visual-divider"></div>

          <div class="visual-reach">
            <div class="reach-label">Persönlich erreichbar</div>
            <div class="reach-cities">
              {regions.map(r => (
                <div class={`reach-chip ${r.primary ? 'reach-chip-primary' : ''}`}>
                  {r.name}
                </div>
              ))}
            </div>
          </div>

          <div class="visual-divider"></div>

          <div class="visual-remote">
            <div class="remote-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" stroke="var(--color-secondary)" stroke-width="1.5"/>
                <path d="M2 12h20M12 2c-2.5 3-4 6.5-4 10s1.5 7 4 10M12 2c2.5 3 4 6.5 4 10s-1.5 7-4 10" stroke="var(--color-secondary)" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="remote-text">
              <div class="remote-title">Remote · Bundesweit</div>
              <div class="remote-sub">Hamburg · Berlin · Frankfurt · Köln · +</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .region-section {
    background: linear-gradient(180deg, transparent, rgba(15,17,23,0.5), transparent);
  }

  .section-label {
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 24px;
    display: block;
  }

  .region-grid {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 80px;
    align-items: center;
  }

  h2 { margin-bottom: 16px; }

  .region-sub {
    color: var(--color-text-secondary);
    max-width: 480px;
    margin-bottom: 40px;
    line-height: 1.7;
  }

  .regions-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .regions-list-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-family: var(--font-heading);
    margin-bottom: 4px;
  }

  .region-item {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .region-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-border-strong);
    flex-shrink: 0;
  }

  .region-dot-primary {
    background: var(--color-primary);
    box-shadow: 0 0 8px var(--color-primary-glow);
  }

  .region-info {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .region-name {
    font-weight: 600;
    font-size: 15px;
    color: var(--color-text-primary);
  }

  .region-desc {
    font-size: 13px;
    color: var(--color-text-muted);
  }

  /* Visual card */
  .visual-card {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .visual-header {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .visual-dot-primary {
    position: relative;
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .visual-dot-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: var(--color-primary);
    box-shadow: 0 0 10px var(--color-primary-glow);
  }

  .pulse-ring {
    position: absolute;
    inset: -5px;
    border-radius: 50%;
    border: 1px solid var(--color-primary);
    opacity: 0;
    animation: pulse-ring 2.5s ease-out infinite;
  }

  @keyframes pulse-ring {
    0%   { transform: scale(0.8); opacity: 0.6; }
    100% { transform: scale(2);   opacity: 0; }
  }

  .visual-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 16px;
    color: var(--color-text-primary);
  }

  .visual-sub {
    font-size: 13px;
    color: var(--color-text-muted);
    margin-top: 2px;
  }

  .visual-divider {
    height: 1px;
    background: var(--color-border);
  }

  /* Reach */
  .reach-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-family: var(--font-heading);
    margin-bottom: 12px;
  }

  .reach-cities {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .reach-chip {
    padding: 5px 12px;
    border-radius: 4px;
    font-size: 13px;
    font-weight: 500;
    background: var(--color-bg-subtle);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
  }

  .reach-chip-primary {
    background: rgba(255, 184, 0, 0.08);
    color: var(--color-primary);
    border-color: rgba(255, 184, 0, 0.2);
    font-weight: 600;
  }

  /* Remote */
  .visual-remote {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .remote-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 212, 255, 0.06);
    border: 1px solid rgba(0, 212, 255, 0.15);
    border-radius: 10px;
    flex-shrink: 0;
  }

  .remote-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 14px;
    color: var(--color-text-primary);
  }

  .remote-sub {
    font-size: 12px;
    color: var(--color-text-muted);
    margin-top: 3px;
  }

  @media (max-width: 900px) {
    .region-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .region-visual {
      max-width: 420px;
    }
  }
</style>
