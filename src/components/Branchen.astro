---
const branchen = [
  {
    id: "handwerk",
    label: "Handwerk",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.77 3.77z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    problem: "Keine Zeit für Marketing — und eine Website, die mehr schadet als hilft.",
    solution: "Website Relaunch, der Aufträge bringt. Automatisches Angebot auf Knopfdruck. Voice Agent für Kundenanfragen.",
    result: "Mehr Anfragen, weniger Zeitverlust. Und ein digitales Gesicht, das Vertrauen schafft.",
    services: ["Website Relaunch", "Automatische Angebote", "KI Voice Agent"],
  },
  {
    id: "arztpraxis",
    label: "Arztpraxis",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M22 12h-4l-3 9L9 3l-3 9H2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    problem: "Überlastete Rezeption, verpasste Anrufe und Patienten, die zur Konkurrenz gehen.",
    solution: "KI Telefonassistent nimmt Anrufe an, bucht Termine und beantwortet Fragen — DSGVO-konform.",
    result: "Kein verpasster Anruf mehr. Ihre Rezeption kann sich um die Patienten im Haus kümmern.",
    services: ["KI Telefonassistent", "Online-Terminbuchung", "KI Chatbot"],
  },
  {
    id: "fitness",
    label: "Fitness & Beauty",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    problem: "Mitglieder kommen und gehen. Kein System für Bindung, Follow-up oder Neukunden.",
    solution: "KI-gestütztes CRM, automatische Follow-ups und eine Website, die Mitglieder gewinnt.",
    result: "Höhere Mitgliederbindung, mehr Online-Buchungen, weniger manuelle Arbeit.",
    services: ["KI CRM", "Automatische Follow-ups", "Website & SEO"],
  },
  {
    id: "pflege",
    label: "Pflege",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    problem: "Rapporterfassung per Hand, Mitarbeiterplanung per Excel und keine digitale Sichtbarkeit.",
    solution: "KI-Rapporterfassung per Sprache, digitale Dokumentation und automatische Mitarbeitergewinnung.",
    result: "Stunden täglich zurückgewonnen. Bessere Dokumentation. Mehr qualifizierte Bewerber.",
    services: ["KI Rapporterfassung", "Digitale Doku", "Mitarbeitergewinnung"],
  },
  {
    id: "reinigung",
    label: "Reinigung",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    problem: "Angebote werden manuell erstellt, Aufträge gehen verloren und neue Kunden sind schwer zu finden.",
    solution: "Automatische Angebotserstellung, KI-Chatbot für Anfragen und lokales SEO für Google.",
    result: "Weniger Büroarbeit, mehr Aufträge, besser auf Google gefunden.",
    services: ["Automatische Angebote", "KI Chatbot", "Local SEO"],
  },
];
---

<section id="branchen" class="section-padding" aria-labelledby="branchen-heading">
  <div class="container">
    <div class="section-label reveal">Branchen</div>
    <h2 id="branchen-heading" class="reveal" data-delay="0.1">
      Wir kennen Ihre Branche.<br />
      <span class="text-amber">Nicht nur Ihre Technologie.</span>
    </h2>
    <p class="section-sub reveal" data-delay="0.2">
      Jede Branche hat eigene Probleme. Generische Lösungen bringen nichts.
      Wir kennen die Schmerzpunkte — und arbeiten gezielt daran.
    </p>

    <!-- Tabs -->
    <div class="tabs-wrap" role="tablist" aria-label="Branchenauswahl">
      {branchen.map((b, i) => (
        <button
          class={`tab-btn ${i === 0 ? 'active' : ''}`}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-controls={`panel-${b.id}`}
          id={`tab-${b.id}`}
          data-tab={b.id}
        >
          <span set:html={b.icon} />
          {b.label}
        </button>
      ))}
    </div>

    <!-- Panels -->
    <div class="panels">
      {branchen.map((b, i) => (
        <div
          class={`panel ${i === 0 ? 'active' : ''}`}
          role="tabpanel"
          id={`panel-${b.id}`}
          aria-labelledby={`tab-${b.id}`}
          hidden={i !== 0}
        >
          <div class="panel-inner">
            <div class="panel-content">
              <div class="panel-block">
                <div class="panel-block-label">Das Problem</div>
                <p class="panel-text">{b.problem}</p>
              </div>
              <div class="panel-block">
                <div class="panel-block-label">Unsere Lösung</div>
                <p class="panel-text">{b.solution}</p>
              </div>
              <div class="panel-block">
                <div class="panel-block-label">Das Ergebnis</div>
                <p class="panel-text panel-result">{b.result}</p>
              </div>
            </div>
            <div class="panel-services">
              <div class="services-label">Relevante Leistungen</div>
              <ul class="services-list" role="list">
                {b.services.map(svc => (
                  <li class="services-list-item">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path d="M20 6L9 17l-5-5" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    {svc}
                  </li>
                ))}
              </ul>
              <a href={`/branchen/${b.id}`} class="btn-secondary panel-cta">
                Mehr erfahren
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-label {
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 24px;
  }

  .section-sub {
    color: var(--color-text-secondary);
    max-width: 560px;
    margin-bottom: 48px;
  }

  /* Tabs */
  .tabs-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 32px;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0;
  }

  .tab-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    color: var(--color-text-muted);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
    border-radius: 4px 4px 0 0;
  }

  .tab-btn svg {
    color: inherit;
    transition: color 0.2s;
  }

  .tab-btn:hover {
    color: var(--color-text-primary);
  }

  .tab-btn.active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }

  /* Panels */
  .panel {
    display: none;
  }

  .panel.active {
    display: block;
    animation: fadeSlideIn 0.3s ease;
  }

  @keyframes fadeSlideIn {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .panel-inner {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 48px;
    padding: 40px;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    border-top-left-radius: 0;
  }

  .panel-content {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .panel-block {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .panel-block-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-family: var(--font-heading);
  }

  .panel-text {
    font-size: 16px;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .panel-result {
    color: var(--color-text-primary);
    font-weight: 500;
  }

  .panel-services {
    border-left: 1px solid var(--color-border);
    padding-left: 48px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .services-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    font-family: var(--font-heading);
  }

  .services-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .services-list-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--color-text-primary);
    font-weight: 500;
  }

  .panel-cta {
    padding: 10px 18px;
    font-size: 14px;
    margin-top: auto;
  }

  @media (max-width: 768px) {
    .panel-inner {
      grid-template-columns: 1fr;
      padding: 28px;
    }
    .panel-services {
      border-left: none;
      border-top: 1px solid var(--color-border);
      padding-left: 0;
      padding-top: 24px;
    }
    .tab-btn { padding: 10px 14px; font-size: 13px; }
  }
</style>

<script>
  const tabBtns = document.querySelectorAll('.tab-btn') as NodeListOf<HTMLButtonElement>;
  const panels  = document.querySelectorAll('.panel') as NodeListOf<HTMLElement>;

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = btn.dataset.tab!;

      tabBtns.forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });
      panels.forEach(p => {
        p.classList.remove('active');
        p.hidden = true;
      });

      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
      const panel = document.getElementById(`panel-${targetId}`)!;
      panel.classList.add('active');
      panel.hidden = false;
    });
  });
</script>
