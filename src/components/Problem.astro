---
const problems = [
  {
    segment: "Handwerker",
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.77 3.77z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    problem: "Ihre Mitbewerber haben moderne Websites. Ihre ist von 2017.",
    pain: "Neukunden googeln — und buchen den Nächsten, weil Ihre Website nicht überzeugt.",
    solution: "Website Relaunch + SEO, der Anfragen generiert statt abschreckt.",
    color: "amber",
  },
  {
    segment: "Arztpraxis",
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    problem: "Ihr Telefon klingelt — aber niemand nimmt ab. Patienten buchen woanders.",
    pain: "Jeder verpasste Anruf ist ein verlorener Patient. Oft für immer.",
    solution: "KI Telefonassistent, der rund um die Uhr Termine annimmt — ohne Wartemusik.",
    color: "cyan",
  },
  {
    segment: "Mittelstand",
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    problem: "Ihre Mitarbeitenden tippen Angebote manuell. Stunden täglich, für etwas das KI in Sekunden erledigt.",
    pain: "Zeit ist Ihr wertvollstes Gut — und sie verpufft in wiederkehrenden Aufgaben.",
    solution: "Prozessautomatisierung, die Ihrem Team Zeit zurückgibt.",
    color: "amber",
  },
];
---

<section class="section-padding" aria-labelledby="problem-heading">
  <div class="container">
    <!-- Section label -->
    <div class="section-label reveal">Das Problem</div>

    <h2 id="problem-heading" class="reveal" data-delay="0.1">
      Wann haben Sie zuletzt<br />
      <span class="text-amber">Kunden verloren</span> — ohne es zu wissen?
    </h2>

    <p class="section-sub reveal" data-delay="0.2">
      Drei Branchen. Drei unterschiedliche Probleme. Eine gemeinsame Ursache: fehlende digitale Infrastruktur.
    </p>

    <!-- Problem cards -->
    <div class="problem-grid">
      {problems.map((item, i) => (
        <article
          class={`problem-card reveal card ${item.color === 'cyan' ? 'card-cyan' : ''}`}
          data-delay={String(0.1 * (i + 1))}
          aria-label={`Problem: ${item.segment}`}
        >
          <div class="card-icon" set:html={item.icon} />
          <div class="card-segment">{item.segment}</div>
          <h3 class="card-problem">„{item.problem}"</h3>
          <p class="card-pain">{item.pain}</p>
          <div class="card-divider" aria-hidden="true"></div>
          <div class="card-solution">
            <span class="solution-label">Unsere Antwort</span>
            <p>{item.solution}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .section-label {
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 24px;
  }

  h2 {
    margin-bottom: 20px;
  }

  .section-sub {
    color: var(--color-text-secondary);
    font-size: 18px;
    max-width: 600px;
    margin-bottom: 64px;
  }

  .problem-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .problem-card {
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .card-cyan {
    border-color: rgba(0, 212, 255, 0.2);
  }

  .card-cyan .card-icon svg {
    color: var(--color-secondary) !important;
  }

  .card-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 184, 0, 0.08);
    border-radius: 10px;
    color: var(--color-primary);
    margin-bottom: 4px;
    flex-shrink: 0;
  }

  .card-cyan .card-icon {
    background: rgba(0, 212, 255, 0.08);
  }

  .card-segment {
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .card-problem {
    font-size: 18px;
    font-weight: 700;
    line-height: 1.4;
    color: var(--color-text-primary);
  }

  .card-pain {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .card-divider {
    height: 1px;
    background: var(--color-border);
    margin: 4px 0;
  }

  .card-solution {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .solution-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    font-family: var(--font-heading);
  }

  .card-solution p {
    font-size: 15px;
    color: var(--color-text-primary);
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 900px) {
    .problem-grid { grid-template-columns: 1fr; max-width: 480px; }
  }

  @media (min-width: 640px) and (max-width: 900px) {
    .problem-grid { grid-template-columns: repeat(2, 1fr); max-width: none; }
  }
</style>
